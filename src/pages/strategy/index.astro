const posDialog      = document.getElementById('st-pos-dialog')      as HTMLDialogElement;
const posDialogTitle = document.getElementById('st-pos-dialog-title')!;
const posDialogClose = document.getElementById('st-pos-dialog-close')!;
const posPhaseView   = document.getElementById('st-pos-phase-view')!;
const posViewAvatar  = document.getElementById('st-pos-view-avatar')!;
const posViewName    = document.getElementById('st-pos-view-name')!;
const posViewTc      = document.getElementById('st-pos-view-tc')!;
const posViewStatus  = document.getElementById('st-pos-view-status')!;
const posRemoveBtn   = document.getElementById('st-pos-remove-btn') as HTMLButtonElement;
const posChangeBtn   = document.getElementById('st-pos-change-btn') as HTMLButtonElement;
const posPhaseId     = document.getElementById('st-pos-phase-id')!;
const posPhaseConf   = document.getElementById('st-pos-phase-confirm')!;
const posIdInput     = document.getElementById('st-pos-id-input')    as HTMLInputElement;
const posLookupBtn   = document.getElementById('st-pos-lookup-btn')  as HTMLButtonElement;
const posIdStatus    = document.getElementById('st-pos-id-status')!;
const posPreviewAv   = document.getElementById('st-pos-preview-avatar')!;
const posPreviewNm   = document.getElementById('st-pos-preview-name')!;
const posPreviewTc   = document.getElementById('st-pos-preview-tc')!;
const posConfStatus  = document.getElementById('st-pos-confirm-status')!;
const posBackBtn     = document.getElementById('st-pos-back-btn')    as HTMLButtonElement;
const posSaveBtn     = document.getElementById('st-pos-save-btn')    as HTMLButtonElement;

function openEditDialog(assignmentId: number) {
  const a = assignments.find((x) => x.id === assignmentId);
  if (!a) return;
  editingId     = assignmentId;
  pendingLookup = null;

  const isLeaderSlot = a.is_leader;
  posDialogTitle.textContent = isLeaderSlot ? t('strategy.dialog.titleLeader') : t('strategy.dialog.titleMember');
  posIdStatus.textContent     = '';
  posConfStatus.textContent   = '';
  setStatus(posViewStatus, '');

  // 포지션 비우기 — 어드민만
  posRemoveBtn.hidden = !isAdmin;

  if (a.kingshot_id) {
    // 채워진 슬롯 → Phase 0 (현재 배정 보기)
    const ini = initial(a.nickname);
    if (a.avatar_url) {
      posViewAvatar.innerHTML = `<img src="${escHtml(a.avatar_url)}" width="48" height="48" onerror="this.parentElement.textContent='${escHtml(ini)}'">`;
    } else {
      posViewAvatar.textContent = ini;
    }
    posViewName.textContent = a.nickname ?? '-';
    const tcPart = a.city_level ? `TC ${a.city_level}` : '';
    const idPart = a.kingshot_id ?? '';
    posViewTc.textContent = [tcPart, idPart].filter(Boolean).join(' · ');

    posPhaseView.hidden    = false;
    posPhaseId.hidden      = true;
    posPhaseConf.hidden    = true;
  } else {
    // 빈 슬롯 → Phase 1 (ID 입력)
    posIdInput.value = '';
    posPhaseView.hidden    = true;
    posPhaseId.hidden      = false;
    posPhaseConf.hidden    = true;
  }

  posDialog.showModal();
  if (!a.kingshot_id) setTimeout(() => posIdInput.focus(), 50);
}

function closeEditDialog() {
  if (posDialog.open) posDialog.close();
  editingId     = null;
  pendingLookup = null;
}

function setStatus(el: HTMLElement, msg: string, tone: '' | 'err' | 'ok' = '') {
  el.textContent = msg;
  el.className   = 'st-pos-status' + (tone ? ' is-' + tone : '');
}

async function onLookup() {
  const pid = posIdInput.value.trim();
  if (!/^\d{4,20}$/.test(pid)) {
    setStatus(posIdStatus, '4~20자리 숫자로 입력해 주세요.', 'err');
    return;
  }
  posLookupBtn.disabled = true;
  setStatus(posIdStatus, '조회 중…');
  try {
    const res = await callFn({ action: 'lookup-player', player_id: pid });
    if (!res.ok) {
      const msgs: Record<string, string> = {
        player_not_found:  '해당 킹샷 ID 를 찾을 수 없습니다.',
        invalid_player_id: '유효하지 않은 킹샷 ID 입니다.',
      };
      setStatus(posIdStatus, msgs[res.error] ?? '조회 실패. 다시 시도해 주세요.', 'err');
      return;
    }
    pendingLookup = { nickname: res.nickname, avatar_url: res.avatar_url, city_level: res.city_level, power: res.power ?? null, alliance_abbr: res.alliance_abbr ?? null };
    const ini = initial(res.nickname);
    if (res.avatar_url) {
      posPreviewAv.innerHTML = `<img src="${escHtml(res.avatar_url)}" width="48" height="48" onerror="this.parentElement.textContent='${escHtml(ini)}'">`;
    } else {
      posPreviewAv.textContent = ini;
    }
    posPreviewNm.textContent = res.nickname;
    posPreviewTc.textContent = res.city_level ? `TC ${res.city_level}` : '';
    setStatus(posIdStatus, '');
    posPhaseId.hidden   = true;
    posPhaseConf.hidden = false;
  } finally {
    posLookupBtn.disabled = false;
  }
}

async function onSave() {
  if (editingId === null || !pendingLookup) return;
  if (!authToken) {
    setStatus(posConfStatus, '로그인 후 이용할 수 있습니다.', 'err');
    return;
  }
  posSaveBtn.disabled = true;
  setStatus(posConfStatus, '저장 중…');
  try {
    const pid = posIdInput.value.trim();
    const res = await callFn({
      action:        'upsert-position',
      token:         authToken,
      id:            editingId,
      kingshot_id:   pid,
      nickname:      pendingLookup.nickname,
      avatar_url:    pendingLookup.avatar_url,
      city_level:    pendingLookup.city_level,
      power:         pendingLookup.power,
      alliance_abbr: pendingLookup.alliance_abbr,
    });
    if (!res.ok) {
      const msgs: Record<string, string> = {
        not_admin:     '관리자 권한이 없습니다.',
        invalid_token: '인증이 만료되었습니다. 다시 로그인해 주세요.',
      };
      setStatus(posConfStatus, msgs[res.error] ?? '저장 실패.', 'err');
      return;
    }
    closeEditDialog();
    await reloadData();
  } finally {
    posSaveBtn.disabled = false;
  }
}

async function onClear() {
  if (editingId === null || !authToken) return;
  posRemoveBtn.disabled = true;
  setStatus(posViewStatus, '처리 중…');
  try {
    const res = await callFn({ action: 'clear-position', token: authToken, id: editingId });
    if (!res.ok) { setStatus(posViewStatus, '실패. 다시 시도해 주세요.', 'err'); return; }
    closeEditDialog();
    await reloadData();
  } finally {
    posRemoveBtn.disabled = false;
  }
}

posDialogClose.addEventListener('click', closeEditDialog);
posDialog.addEventListener('click', (e) => { if (e.target === posDialog) closeEditDialog(); });
posLookupBtn.addEventListener('click', onLookup);
posIdInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') onLookup(); });
posBackBtn.addEventListener('click', () => {
  posPhaseId.hidden   = false;
  posPhaseConf.hidden = true;
  setStatus(posConfStatus, '');
});
posSaveBtn.addEventListener('click', onSave);

// Phase 0: 포지션 비우기 버튼
posRemoveBtn.addEventListener('click', onClear);

// Phase 0: 변경하기 버튼 → Phase 1
posChangeBtn.addEventListener('click', () => {
  posIdInput.value    = '';
  posIdStatus.textContent = '';
  posPhaseView.hidden = true;
  posPhaseId.hidden   = false;
  setTimeout(() => posIdInput.focus(), 50);
});

// ── 이벤트 위임: 편집 클릭 ───────────────────────────────────────
function setupEditHandlers() {
  // 집결원 등록 버튼
  flowGrid.querySelectorAll<HTMLButtonElement>('[data-add-member]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const gid      = btn.dataset.addMember!;
      const emptySlot = assignments.find(
        (a) => a.group_id === gid && !a.is_leader && !a.kingshot_id,
      );
      if (!emptySlot) { alert('배정 가능한 슬롯이 없습니다.'); return; }
      openEditDialog(emptySlot.id);
    });
  });

  // 집결장 등록 버튼 (빈 프레임)
  flowGrid.querySelectorAll<HTMLButtonElement>('[data-id].st-rep-add-btn').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      openEditDialog(Number(btn.dataset.id));
    });
  });

  // 배정된 카드 클릭 → 상세보기 다이얼로그 (모든 인증 사용자)
  flowGrid.querySelectorAll<HTMLElement>('[data-assignment-id]').forEach((el) => {
    const a = assignments.find((x) => x.id === Number(el.dataset.assignmentId));
    if (!a?.kingshot_id) return; // 빈 슬롯은 스킵
    el.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('.st-rep-add-btn,.st-member-add-row')) return;
      openDetailDialog(Number(el.dataset.assignmentId));
    });
  });
}

// ── 드래그 & 드롭 ────────────────────────────────────────────────
function setupDragDrop() {
  // 드래그 소스: 채워진 카드만
  flowGrid.querySelectorAll<HTMLElement>('[data-assignment-id][draggable="true"]').forEach((el) => {
    el.addEventListener('dragstart', (e) => {
      dragSourceId = Number(el.dataset.assignmentId);
      el.classList.add('is-dragging');
      e.dataTransfer!.effectAllowed = 'move';
    });
    el.addEventListener('dragend', () => {
      el.classList.remove('is-dragging');
      flowGrid.querySelectorAll('.is-drag-over').forEach((t) => t.classList.remove('is-drag-over'));
    });
  });

  // 드롭 타겟: 채워진 슬롯 + 빈 슬롯 모두
  flowGrid.querySelectorAll<HTMLElement>('[data-assignment-id]').forEach((el) => {
    el.addEventListener('dragover', (e) => {
      if (dragSourceId === null) return;
      e.preventDefault();
      e.dataTransfer!.dropEffect = 'move';
      if (dragSourceId !== Number(el.dataset.assignmentId)) {
        el.classList.add('is-drag-over');
      }
    });
    el.addEventListener('dragleave', (e) => {
      // 자식 요소로 이동 시 오발 방지
      if (!el.contains(e.relatedTarget as Node)) {
        el.classList.remove('is-drag-over');
      }
    });
    el.addEventListener('drop', async (e) => {
      e.preventDefault();
      el.classList.remove('is-drag-over');
      const targetId = Number(el.dataset.assignmentId);
      if (dragSourceId === null || dragSourceId === targetId || !authToken) return;
      const srcId = dragSourceId;
      dragSourceId = null;
      const res = await callFn({ action: 'swap-positions', token: authToken, id_a: srcId, id_b: targetId });
      if (res.ok) await reloadData();
    });
  });
}

// ── 포지션 전체 갱신 (어드민) ────────────────────────────────────
const refreshBtn = document.getElementById('st-refresh-btn') as HTMLButtonElement;

async function onRefreshPositions() {
  if (!authToken) return;
  refreshBtn.disabled = true;
  const svgIcon = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M23 4v6h-6"/><path d="M1 20v-6h6"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>`;
  refreshBtn.innerHTML = svgIcon + '갱신 중…';
  try {
    const res = await callFn({ action: 'refresh-all-positions', token: authToken });
    if (res.ok) {
      await reloadData();
      alert(`갱신 완료 (${res.refreshed}명${res.failed ? ` / 실패 ${res.failed}명` : ''})`);
    } else {
      alert('갱신 실패: ' + (res.error ?? 'unknown'));
    }
  } finally {
    refreshBtn.disabled = false;
    refreshBtn.innerHTML = svgIcon + '포지션 갱신';
  }
}

refreshBtn.addEventListener('click', onRefreshPositions);

// ── 데이터 로드 ──────────────────────────────────────────────────
async function reloadData() {
  setLoading(true);
  try { assignments = await fetchAssignments(); }
  catch { assignments = []; }
  finally { setLoading(false); }
  renderFlowGrid();
}

// ── 채팅 ────────────────────────────────────────────────────────
const chatMsgsEl     = document.getElementById('st-chat-messages')!;
const chatNoticeEl   = document.getElementById('st-chat-notice')!;
const chatInputArea  = document.getElementById('st-chat-input-area')!;
const chatTextarea   = document.getElementById('st-chat-textarea')   as HTMLTextAreaElement;
const chatSendBtn    = document.getElementById('st-chat-send-btn')   as HTMLButtonElement;
const chatCooldownEl = document.getElementById('st-chat-cooldown')!;

function isScrolledToBottom(): boolean {
  const el = chatMsgsEl;
  return el.scrollHeight - el.scrollTop - el.clientHeight < 80;
}

function scrollChatBottom(force = false) {
  if (force || isScrolledToBottom()) {
    chatMsgsEl.scrollTop = chatMsgsEl.scrollHeight;
  }
}

function maybeInsertDateDivider(iso: string) {
  const d = fmtDate(iso);
  if (d !== lastChatDate) {
    lastChatDate = d;
    const div = document.createElement('div');
    div.className = 'st-chat-date';
    div.textContent = d;
    chatMsgsEl.appendChild(div);
  }
}

function createChatRow(message: string, time: string, mine: boolean): HTMLElement {
  const row = document.createElement('div');
  row.className = 'st-chat-row';

  const bubble = document.createElement('div');
  bubble.className = 'st-chat-bubble';
  bubble.textContent = message;

  const timeEl = document.createElement('span');
  timeEl.className = 'st-chat-time';
  timeEl.textContent = time;

  // 내 메시지: 시간 왼쪽, 버블 오른쪽 (row-reverse 로 처리됨)
  row.appendChild(timeEl);
  row.appendChild(bubble);

  return row;
}

function createChatGroup(msg: ChatMessage, mine: boolean, showAv: boolean): HTMLElement {
  const group = document.createElement('div');
  group.className = `st-chat-grp${mine ? ' is-mine' : ''}`;
  group.dataset.kid = msg.kingshot_id;
  group.dataset.lastTime = String(new Date(msg.created_at).getTime());

  if (!mine) {
    if (showAv) {
      const av = document.createElement('div');
      av.className = 'st-chat-av';
      if (msg.avatar_url) {
        av.innerHTML = `<img src="${escHtml(msg.avatar_url)}" width="34" height="34">`;
      } else {
        av.textContent = initial(msg.nickname);
      }
      group.appendChild(av);
    } else {
      const placeholder = document.createElement('div');
      placeholder.className = 'st-chat-av-empty';
      group.appendChild(placeholder);
    }
  }

  const body = document.createElement('div');
  body.className = 'st-chat-grp-body';

  if (!mine && showAv) {
    const nick = document.createElement('div');
    nick.className = 'st-chat-nick';
    nick.textContent = msg.nickname;
    body.appendChild(nick);
  }

  body.appendChild(createChatRow(msg.message, fmtTime(msg.created_at), mine));
  group.appendChild(body);
  return group;
}

function appendChatMessage(msg: ChatMessage) {
  const mine     = msg.kingshot_id === authRecord?.kingshot_id;
  const atBottom = isScrolledToBottom();

  maybeInsertDateDivider(msg.created_at);

  const msgTime  = new Date(msg.created_at).getTime();
  const lastTime = lastChatGroup ? Number(lastChatGroup.dataset.lastTime) : 0;
  const canGroup = lastChatKid === msg.kingshot_id
    && (msgTime - lastTime) < 5 * 60 * 1000;

  if (canGroup && lastChatGroup) {
    // 기존 그룹에 버블 추가
    const body = lastChatGroup.querySelector('.st-chat-grp-body')!;
    body.appendChild(createChatRow(msg.message, fmtTime(msg.created_at), mine));
    lastChatGroup.dataset.lastTime = String(msgTime);
  } else {
    // 새 그룹 생성
    const group = createChatGroup(msg, mine, true);
    chatMsgsEl.appendChild(group);
    lastChatGroup = group;
    lastChatKid   = msg.kingshot_id;
  }

  if (atBottom || mine) scrollChatBottom(true);
}

async function loadChatHistory() {
  try {
    const res = await callFn({ action: 'chat-fetch' });
    if (!res.ok || !Array.isArray(res.messages)) return;
    lastChatDate = '';
    chatMsgsEl.innerHTML = '';
    lastChatKid   = '';
    lastChatGroup = null;
    for (const m of res.messages) appendChatMessage(m);
    scrollChatBottom(true);
  } catch { /* 채팅 초기 로드 실패는 무시 */ }
}

// 레이트리밋 쿨다운 타이머
function startCooldownTimer(endMs: number) {
  if (cdTimerId) clearInterval(cdTimerId);
  updateCooldownUI(endMs);
  cdTimerId = setInterval(() => updateCooldownUI(endMs), 1000);
}

function updateCooldownUI(endMs: number) {
  const remaining = Math.ceil((endMs - Date.now()) / 1000);
  if (remaining <= 0) {
    if (cdTimerId) { clearInterval(cdTimerId); cdTimerId = null; }
    chatCooldownEl.textContent   = '';
    chatTextarea.disabled        = false;
    chatSendBtn.disabled         = false;
    chatTextarea.placeholder     = t('strategy.chat.placeholder');
    return;
  }
  const m = Math.floor(remaining / 60);
  const s = remaining % 60;
  chatCooldownEl.textContent   = m > 0
    ? t('strategy.chat.cooldownMinSec', { m: String(m), s: s.toString().padStart(2, '0') })
    : t('strategy.chat.cooldownSec', { s: String(s) });
  chatTextarea.disabled        = true;
  chatSendBtn.disabled         = true;
  chatTextarea.placeholder     = t('strategy.chat.cooldownPlaceholder');
}

function checkCooldown() {
  const stored = localStorage.getItem(CHAT_CD_KEY);
  if (!stored) return;
  const endMs = Number(stored);
  if (isNaN(endMs) || endMs <= Date.now()) {
    localStorage.removeItem(CHAT_CD_KEY);
    return;
  }
  startCooldownTimer(endMs);
}

function setCooldown(retryAfterSec: number) {
  const endMs = Date.now() + retryAfterSec * 1000;
  localStorage.setItem(CHAT_CD_KEY, String(endMs));
  startCooldownTimer(endMs);
}

async function onChatSend() {
  if (!authToken) return;
  const text = chatTextarea.value.trim();
  if (!text) return;

  // 클라이언트 레이트리밋 확인
  const stored = localStorage.getItem(CHAT_CD_KEY);
  if (stored) {
    const endMs = Number(stored);
    if (!isNaN(endMs) && endMs > Date.now()) {
      startCooldownTimer(endMs);
      return;
    }
  }

  chatSendBtn.disabled  = true;
  chatTextarea.disabled = true;

  try {
    const res = await callFn({ action: 'chat-send', token: authToken, message: text });
    if (!res.ok) {
      if (res.error === 'rate_limited') {
        setCooldown(res.retry_after ?? 300);
      }
      // 실패해도 textarea 복구 (finally에서 처리)
      return;
    }

    // 전송 성공 — 즉시 UI에 추가 (Realtime 도달 전에 보여주기)
    if (res.message) {
      recentSentIds.add(res.message.id); // Realtime 중복 방지용 id 등록
      appendChatMessage(res.message);
    }

    chatTextarea.value = '';
    chatTextarea.style.height = 'auto';
    // 5분 쿨다운 시작
    setCooldown(CHAT_LIMIT_MS / 1000);
  } catch { /* 전송 실패 무시 */ }
  finally {
    // 쿨다운이 걸려있지 않으면 버튼 복구
    const cd = localStorage.getItem(CHAT_CD_KEY);
    if (!cd || Number(cd) <= Date.now()) {
      chatSendBtn.disabled  = false;
      chatTextarea.disabled = false;
    }
  }
}

chatSendBtn.addEventListener('click', onChatSend);
chatTextarea.addEventListener('keydown', (e) => {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); onChatSend(); }
});

// 자동 높이 조절
chatTextarea.addEventListener('input', () => {
  chatTextarea.style.height = 'auto';
  chatTextarea.style.height = Math.min(chatTextarea.scrollHeight, 80) + 'px';
});

// ── Supabase Realtime 채팅 구독 ──────────────────────────────────
let chatChannel: ReturnType<typeof supabase.channel> | null = null;

function subscribeChatRealtime() {
  if (chatChannel) return;
  chatChannel = supabase
    .channel('strategy-chat-rt')
    .on(
      'postgres_changes' as any,
      { event: 'INSERT', schema: 'public', table: 'strategy_chat' },
      (payload: any) => {
        const msg = payload.new as ChatMessage;
        // 이미 즉시 추가한 내 메시지 — 중복 스킵
        if (recentSentIds.has(msg.id)) {
          recentSentIds.delete(msg.id);
          return;
        }
        appendChatMessage(msg);
      },
    )
    .subscribe();
}

function unsubscribeChatRealtime() {
  if (chatChannel) { supabase.removeChannel(chatChannel); chatChannel = null; }
}

// ── 인증 흐름 ────────────────────────────────────────────────────
async function verifyAndInit() {
  if (!authRecord || !authToken) { showGate(); return; }

  gateStatus.textContent = '접근 권한 확인 중…';
  gateStatus.hidden = false;
  gateEl.hidden     = false;

  let res: any;
  try {
    res = await callFn({ action: 'verify-access', token: authToken });
  } catch {
    showGate('서버 연결에 실패했습니다. 잠시 후 다시 시도해 주세요.');
    return;
  }

  if (!res?.ok) {
    const msgs: Record<string, string> = {
      not_member:    '1767 서버 KvK 설문 미참여자입니다.',
      level_too_low: `센터 레벨이 부족합니다. (현재: TC ${res?.city_level ?? '?'} / 필요: TC 26 이상)`,
      invalid_token: '인증이 만료되었습니다. 다시 로그인해 주세요.',
    };
    showGate(msgs[res?.error] ?? '접근 권한 확인 실패. 잠시 후 다시 시도해 주세요.');
    return;
  }

  try { isAdmin = await checkAdmin(authRecord.kingshot_id); }
  catch { isAdmin = false; }

  refreshBtn.hidden = !isAdmin;
  showMain();

  // 채팅 UI
  chatNoticeEl.hidden  = true;
  chatInputArea.hidden = false;
  checkCooldown();

  // 채팅 초기 로드 + Realtime 구독
  await loadChatHistory();
  subscribeChatRealtime();

  // 전략 배정 로드
  await reloadData();
}

async function init() {
  const auth = readAuth();
  authRecord = auth?.record ?? null;
  authToken  = auth?.token  ?? null;

  if (!authRecord || !authToken) {
    showGate();
    // 미인증에도 채팅은 읽기 전용 표시
    chatNoticeEl.hidden  = false;
    chatInputArea.hidden = true;
    await loadChatHistory();
    subscribeChatRealtime();
    return;
  }

  await verifyAndInit();
}

gateBtnEl.addEventListener('click', () => {
  document.dispatchEvent(new CustomEvent('app-open-auth'));
});

document.addEventListener('app-auth-changed', async () => {
  const auth = readAuth();
  authRecord = auth?.record ?? null;
  authToken  = auth?.token  ?? null;
  if (authRecord && authToken) {
    await verifyAndInit();
  } else {
    showGate();
    isAdmin = false;
    refreshBtn.hidden    = true;
    chatNoticeEl.hidden  = false;
    chatInputArea.hidden = true;
    unsubscribeChatRealtime();
  }
});

// 페이지 언로드 시 Realtime 정리
window.addEventListener('beforeunload', unsubscribeChatRealtime);

// 언어 변경 시 동적으로 생성된 그리드 콘텐츠 재렌더
onLangChange(() => {
  if (assignments.length > 0) renderFlowGrid();
  // 시나리오 설명 텍스트 갱신 (data-i18n 속성은 setScenario 에서 이미 설정됨 → applyTranslations 가 처리)
});

init();
</script>
