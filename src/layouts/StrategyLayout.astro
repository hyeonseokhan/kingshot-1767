---
// StrategyLayout — 전략 페이지 전용 래퍼.
// BaseLayout(통합 헤더) 위에 strategy-main 영역(3컬럼 그리드 최적화).
import BaseLayout from '@/layouts/BaseLayout.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = '공격 전략 — 1767 서버',
  description = 'KVK 설문 참여자 기반 포지션별 공격 담당 전략 안내',
} = Astro.props;
---

<BaseLayout title={title} description={description} mainClass="strategy-main">
  <slot />
</BaseLayout>

<style is:global>
  .strategy-main {
    /* st-grid 가 자체 max-width 와 margin auto 를 갖고 있어 추가 폭 제한 불필요 */
    width: 100%;
    overflow-x: hidden;
  }
</style>
