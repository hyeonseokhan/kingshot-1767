---
// 5 거점 카드 그리드 컨테이너 — SLOT_RENDER_ORDER 대로 정렬.
// SSR 시점에 page 에서 targets[] 전달, 누락된 슬롯은 fallback (등록되지 않은 거점) 으로 채움.
import type { TargetView } from '@/lib/castle-battle/types';
import { SLOT_RENDER_ORDER } from '@/lib/castle-battle/types';
import TargetCard from './TargetCard.astro';

interface Props {
  targets: TargetView[];
}
const { targets } = Astro.props;

const bySlot = new Map(targets.map((t) => [t.slot, t]));
const ordered = SLOT_RENDER_ORDER.map((slot) => bySlot.get(slot) ?? null);
---

<section class="cb-battlefield">
  {ordered.map((target, i) =>
    target ? (
      <TargetCard target={target} />
    ) : (
      <article class="cb-target cb-target-empty" data-slot={SLOT_RENDER_ORDER[i]}>
        <div class="cb-target-empty-body">
          <span class="cb-target-empty-text">거점 미등록</span>
        </div>
      </article>
    ),
  )}
</section>

<style>
  .cb-target-empty {
    background: rgba(15, 23, 42, 0.02);
    border: 1px dashed var(--cb-border-strong);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .cb-target-empty-body {
    padding: 16px;
    text-align: center;
  }
  .cb-target-empty-text {
    font-size: 12px;
    font-weight: 600;
    color: var(--cb-text-dim);
  }
</style>
