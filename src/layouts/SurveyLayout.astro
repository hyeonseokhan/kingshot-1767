---
// SurveyLayout — KvK 설문 페이지 전용.
// BaseLayout(통합 헤더) 위에 KvK 콘텐츠에 맞는 narrow main 영역 + footer 를 얹는다.
// 로그아웃 버튼은 헤더의 header-actions slot 으로 이전 (survey-kvk.ts 가 그대로 토글).
import BaseLayout from '@/layouts/BaseLayout.astro';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'KVK Speed-up Survey', description = 'KVK speed-up inventory survey' } =
  Astro.props;
---

<BaseLayout title={title} description={description} mainClass="survey-main">
  <button
    slot="header-actions"
    id="sk-logout-btn"
    class="survey-logout-btn"
    type="button"
    hidden
    data-i18n-attr-title="survey.header.logoutTooltip"
  >
    <svg
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
      <polyline points="16 17 21 12 16 7"></polyline>
      <line x1="21" y1="12" x2="9" y2="12"></line>
    </svg>
    <span data-i18n="survey.header.logout">로그아웃</span>
  </button>

  <slot />
</BaseLayout>

<style is:global>
  /* survey-main 폭은 KvK 콘텐츠 (PC 세로 모드) 에 맞춰 좁게 — 1100px 캡. */
  .survey-main {
    max-width: 1100px;
    width: 100%;
    margin: 0 auto;
    padding: 16px;
  }
  @media (max-width: 600px) {
    .survey-main { padding: 10px; }
  }
  /* 헤더 안 로그아웃 버튼 — 인증 후에만 노출 (survey-kvk.ts 가 hidden 토글). */
  .survey-logout-btn {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 5px 10px;
    border-radius: 6px;
    background: rgba(15, 23, 42, 0.05);
    border: 1px solid var(--brand-border);
    color: var(--brand-text);
    font: inherit;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
  }
  .survey-logout-btn:hover {
    background: rgba(15, 23, 42, 0.08);
    border-color: var(--brand-border-strong);
  }

  /* footer 는 BaseLayout 의 app-footer 가 통합 제공 — survey-footer 룰은 제거. */
</style>
