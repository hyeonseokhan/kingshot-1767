    <!-- ===== 버프 예약 다이얼로그 (마감 후 [버프 예약] 클릭 시 노출) ===== -->
    <dialog class="sk-buff-overlay" id="sk-buff-overlay" aria-labelledby="sk-buff-overlay-title">
      <div class="sk-buff-overlay-card">
        <header class="sk-buff-overlay-head">
          <strong id="sk-buff-overlay-title" data-i18n="survey.kvkBuff.title">버프 예약</strong>
          <!-- !!! TEST_MODE 표시 — sk-buff-page.is-test 일 때만 노출 (CSS) -->
          <span class="sk-buff-test-badge" data-i18n="survey.kvkBuff.test.badge">TEST</span>

          <!-- admin 도구 — .sk-buff-page.is-admin 일 때만 노출 (CSS).
               [예약 시작]: 시작 전(.is-started X)만 활성, 시작 후 disabled
               [예약 마감]: 시작 후만 활성, 시작 전 disabled
               JS 가 disabled 토글 + state.bootstrapped_at 동기화 -->
          <button type="button" class="sk-buff-admin-btn sk-buff-start-btn" id="sk-buff-start-btn"
            data-i18n="survey.kvkBuff.startButton">예약 시작</button>
          <button type="button" class="sk-buff-admin-btn sk-buff-finalize-btn" id="sk-buff-finalize-btn"
            data-i18n="survey.kvkBuff.finalizeButton">예약 마감</button>

          <!-- !!! TEST_MODE 전용 [재시작] — admin + test mode 동시 만족 시 노출 (CSS) -->
          <button type="button" class="sk-buff-test-reset-btn" id="sk-buff-test-reset"
            data-i18n="survey.kvkBuff.test.resetButton">재시작</button>
          <button type="button" class="sk-dialog-close" id="sk-buff-overlay-close" aria-label="Close">&times;</button>
        </header>
        <div class="sk-buff-overlay-body">
          <div class="sk-buff-page" id="sk-buff-page">
            <button type="button" class="sk-notice-trigger" id="sk-buff-notice-trigger">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="12" y1="16" x2="12" y2="12"></line>
                <line x1="12" y1="8" x2="12.01" y2="8"></line>
              </svg>
              <span data-i18n="survey.kvkBuff.notice.triggerLabel">필독 안내문</span>
            </button>

            <!-- !!! TEST_MODE 전용 — 선착순 진행률 카드. 노출 결정은 CSS (.sk-buff-page.is-test) 한 곳에서만.
                 (hidden 속성 사용 금지 — CSS display 토글과 충돌 시 일부 브라우저에서 안 풀리는 회귀.)
                 운영(순차)에선 .sk-buff-progress { display:none } 로 자동 hide. -->
            <section class="sk-buff-progress" id="sk-buff-progress">
              <div class="sk-buff-progress-head">
                <span class="sk-buff-progress-label" id="sk-buff-progress-label">선착순 진행</span>
                <span class="sk-buff-progress-count">
                  <span id="sk-buff-progress-done">0</span>
                  <span class="sk-buff-progress-divider">/</span>
                  <span id="sk-buff-progress-total">0</span>
                </span>
              </div>
              <div class="sk-buff-progress-bar">
                <div class="sk-buff-progress-fill" id="sk-buff-progress-fill" style="width:0%"></div>
              </div>
            </section>

            <section class="sk-buff-current" id="sk-buff-current">
              <div class="sk-buff-current-main">
                <div class="sk-buff-current-photo-wrap">
                  <div class="sk-buff-current-photo-empty" id="sk-buff-current-photo-empty">?</div>
                  <img class="sk-buff-current-photo" id="sk-buff-current-photo" alt="" hidden />
                </div>
                <div class="sk-buff-current-meta">
                  <div class="sk-buff-current-name" id="sk-buff-current-name">-</div>
                  <div class="sk-buff-current-id" id="sk-buff-current-id">-</div>
                </div>
                <!-- [변경] — admin 만 노출 (CSS 게이트). 클릭 시 사용자 목록 다이얼로그.
                     기존 [스킵] 자동 swap 패턴 → admin 이 명시적으로 다음 차례 사용자 지정. -->
                <button type="button" class="sk-buff-skip-btn" id="sk-buff-replace-btn" data-i18n="survey.kvkBuff.replaceButton">변경</button>
                <span class="sk-buff-current-badge">
                  <span data-i18n="survey.kvkBuff.selecting">선택중</span>
                  <span class="sk-buff-current-elapsed" id="sk-buff-current-elapsed">0:00</span>
                </span>
                <svg class="sk-buff-current-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </div>
              <div class="sk-buff-current-queue-wrap">
                <div class="sk-buff-current-queue">
