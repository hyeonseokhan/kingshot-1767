---
// 5 거점 카드 그리드 컨테이너 — SLOT_RENDER_ORDER 대로 정렬.
// SSR 시점에 page 에서 targets[] 전달, 누락된 슬롯은 fallback (등록되지 않은 거점) 으로 채움.
import type { TargetView, CbTargetSlot } from '@/lib/castle-battle/types';
import { SLOT_RENDER_ORDER } from '@/lib/castle-battle/types';
import TargetCard from './TargetCard.astro';

interface Props {
  targets: TargetView[];
}
const { targets } = Astro.props;

const bySlot = new Map(targets.map((t) => [t.slot, t]));

function emptyTarget(slot: CbTargetSlot): TargetView {
  return { target_id: 0, slot, is_open: false, candidates: [], total_votes: 0, leader: null, my_vote: null };
}
---

<section class="cb-battlefield">
  {SLOT_RENDER_ORDER.map((slot) => {
    const target = bySlot.get(slot);
    return target
      ? <TargetCard target={target} />
      : <TargetCard target={emptyTarget(slot)} isEmpty={true} />;
  })}
</section>
