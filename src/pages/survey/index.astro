                <div class="sk-detail-bar-fill" id="sk-detail-bar-general"></div>
                <div class="sk-detail-bar-pct" id="sk-detail-pct-general">-</div>
              </div>
            </div>
            <div class="sk-detail-bar">
              <div class="sk-detail-bar-head">
                <span class="sk-detail-bar-label"><span class="sk-detail-emoji">🛡️</span>
                  <span data-i18n="survey.kvk.form.training">병사 훈련 가속권</span></span>
                <span class="sk-detail-bar-value" id="sk-detail-training">-</span>
