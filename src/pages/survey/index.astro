              <div class="sk-detail-bar-track">
                <div class="sk-detail-bar-fill" id="sk-detail-bar-training"></div>
                <div class="sk-detail-bar-pct" id="sk-detail-pct-training">-</div>
              </div>
            </div>
            <div class="sk-detail-bar">
              <div class="sk-detail-bar-head">
                <span class="sk-detail-bar-label"><span class="sk-detail-emoji">🔨</span>
