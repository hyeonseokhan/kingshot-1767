---
// 헤더의 🌐 KOR/ENG 토글. 외부 클릭 시 닫힘. 동작 로직: src/scripts/components/lang-switcher.ts
//
// 자기 자신의 라벨 텍스트는 i18n 거치지 않고 두 언어 모두 그대로 노출 (사용자가 현재 언어를 모르는
// 상태에서도 알아볼 수 있게). 트리거 라벨 (KOR/ENG) 만 클라이언트가 lang 에 따라 갱신.
---

<div class="lang-switcher" id="lang-switcher" data-open="false">
  <button
    class="lang-trigger"
    id="lang-trigger"
    type="button"
    aria-haspopup="menu"
    aria-expanded="false"
  >
    <span class="lang-icon" aria-hidden="true">🌐</span>
    <span class="lang-current" id="lang-current">KOR</span>
    <svg
      class="lang-caret"
      width="10"
      height="10"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      aria-hidden="true"
    >
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </button>

  <div class="lang-menu" id="lang-menu" role="menu" hidden>
    <button class="lang-item" type="button" role="menuitem" data-set-lang="ko">
      <span class="lang-check" aria-hidden="true">✓</span>
      <span>한국어</span>
    </button>
    <button class="lang-item" type="button" role="menuitem" data-set-lang="en">
      <span class="lang-check" aria-hidden="true">✓</span>
      <span>English</span>
    </button>
  </div>
</div>

<script>
  import '@/scripts/components/lang-switcher';
</script>

<style>
  .lang-switcher {
    position: relative;
    display: inline-flex;
    align-items: center;
  }

  /* light 헤더 위에 또렷이 보이도록 brand 토큰 사용 — dark 잔재 제거. */
  .lang-trigger {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(15, 23, 42, 0.04);
    border: 1px solid var(--brand-border);
    color: var(--brand-text);
    padding: 5px 10px;
    border-radius: 6px;
    cursor: pointer;
    font-family: inherit;
    font-size: 12.5px;
    font-weight: 600;
    line-height: 1.4;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }
  .lang-trigger:hover {
    background: rgba(124, 58, 237, 0.10);
    border-color: rgba(124, 58, 237, 0.35);
    color: var(--brand-accent);
  }
  .lang-switcher[data-open='true'] .lang-trigger {
    background: rgba(124, 58, 237, 0.14);
    border-color: rgba(124, 58, 237, 0.45);
    color: var(--brand-accent);
  }

  .lang-icon {
    font-size: 13px;
    line-height: 1;
  }

  .lang-current {
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.02em;
  }

  .lang-caret {
    color: currentColor;
    opacity: 0.65;
  }

  .lang-menu {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    min-width: 140px;
    background: var(--brand-surface);
    border: 1px solid var(--brand-border);
    border-radius: 10px;
    box-shadow: 0 12px 28px rgba(15, 23, 42, 0.18);
    padding: 6px;
    display: none;
    flex-direction: column;
    gap: 2px;
    z-index: 200;
  }
  .lang-switcher[data-open='true'] .lang-menu {
    display: flex;
  }

  .lang-item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: none;
    border: none;
    color: var(--brand-text);
    padding: 6px 10px;
    border-radius: 6px;
    font-family: inherit;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    text-align: left;
    line-height: 1.4;
    transition: background 0.12s, color 0.12s;
  }
  .lang-item:hover {
    background: rgba(124, 58, 237, 0.08);
    color: var(--brand-accent);
  }

  .lang-check {
    width: 14px;
    color: var(--brand-accent);
    visibility: hidden;
  }
  .lang-item[data-active='true'] .lang-check {
    visibility: visible;
  }
  .lang-item[data-active='true'] {
    color: var(--brand-accent);
    font-weight: 700;
  }

  /* 1767 사이트는 MobileNav 가 없음 — 모바일에서도 헤더에 LangSwitcher 노출. */
</style>
