---
// 통합 상단 헤더 — KvK 설문 / 캐슬 전투 두 서비스를 탭으로 전환.
// 우측 actions: [페이지별 actions (header-actions slot)] + [계정 인증] + [언어 선택]
// 모바일: nav 숨김 + 햄버거 버튼으로 MobileNav 드로어 토글.
import LangSwitcher from '@/components/LangSwitcher.astro';
import AuthButton from '@/components/AuthButton.astro';
import MobileNav from '@/components/MobileNav.astro';
import { tabs, findActiveTab } from '@/data/navigation';

const activeTab = findActiveTab(Astro.url.pathname);
---

<header class="app-header">
  <div class="app-header-inner">
    <button
      class="mobile-menu-btn"
      id="mobile-menu-btn"
      type="button"
      aria-label="메뉴"
      data-i18n-attr-aria-label="header.menuOpen"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>

    <a class="app-brand" href="/" aria-label="1767 서버 — 홈으로">
      <img src="/logo.png" alt="PNX" width="28" height="28" decoding="async" />
      <span class="app-brand-text" data-i18n="header.title">1767 서버</span>
    </a>

    <nav class="app-nav" aria-label="서비스 메뉴">
      {tabs.map((tab) => (
        <a
          href={tab.path}
          class:list={['app-nav-tab', { 'is-active': activeTab?.id === tab.id }]}
          data-i18n={tab.titleKey}
          aria-current={activeTab?.id === tab.id ? 'page' : undefined}
        >
          {tab.title}
        </a>
      ))}
    </nav>

    <div class="app-header-actions">
      <slot name="header-actions" />
      <AuthButton />
      <LangSwitcher />
    </div>
  </div>
</header>

<MobileNav />

<style>
  .app-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.88);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--brand-border);
    box-shadow: 0 1px 0 rgba(15, 23, 42, 0.03);
    height: var(--header-h);
    flex-shrink: 0;
  }
  .app-header-inner {
    max-width: 1400px;
    height: 100%;
    margin: 0 auto;
    padding: 0 16px;
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .app-brand {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    flex-shrink: 0;
  }
  .app-brand img {
    display: block;
    width: 28px;
    height: 28px;
    flex-shrink: 0;
  }
  .app-brand-text {
    font-size: 14px;
    font-weight: 800;
    color: var(--brand-text);
    letter-spacing: -0.01em;
    transition: color 0.15s;
  }
  .app-brand:hover .app-brand-text { color: var(--brand-accent); }

  .app-nav {
    display: flex;
    gap: 4px;
    flex: 1;
    min-width: 0;
  }
  .app-nav-tab {
    display: inline-flex;
    align-items: center;
    padding: 6px 12px;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 600;
    color: var(--brand-text-dim);
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s, color 0.15s;
  }
  .app-nav-tab:hover {
    background: rgba(15, 23, 42, 0.05);
    color: var(--brand-text);
    text-decoration: none;
  }
  .app-nav-tab.is-active {
    color: var(--brand-accent);
    background: rgba(124, 58, 237, 0.10);
  }

  .app-header-actions {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
    margin-left: auto;
  }

  /* === 햄버거 버튼 === */
  .mobile-menu-btn {
    display: none;
    background: none;
    border: none;
    padding: 6px;
    margin-left: -6px;
    cursor: pointer;
    color: var(--brand-text);
    border-radius: 6px;
    transition: background 0.15s;
  }
  .mobile-menu-btn:hover { background: rgba(15, 23, 42, 0.05); }

  /* === 모바일: 탭 숨김 + 햄버거 노출 === */
  @media (max-width: 768px) {
    .app-header-inner {
      gap: 10px;
      padding: 0 12px;
    }
    .mobile-menu-btn { display: inline-flex; align-items: center; justify-content: center; }
    .app-nav { display: none; }
    /* nav 사라지면 app-brand 와 actions 사이 공간을 actions 의 margin-left:auto 가 흡수 */
  }
  @media (max-width: 600px) {
    .app-brand-text {
      font-size: 13px;
    }
    .app-brand img { width: 24px; height: 24px; }
  }
</style>
