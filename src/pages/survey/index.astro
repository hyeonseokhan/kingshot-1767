---
import SurveyLayout from '@/layouts/SurveyLayout.astro';
import '@/styles/kvk-survey/main.css';
// 버프 예약 다이얼로그 (sk-buff-*) — 마감 후 [버프 예약] 클릭 시 노출.
import '@/styles/kvk-survey/buff.css';
---

<SurveyLayout
  title="KVK 가속권 현황 조사 — Kingshot"
  description="KVK 이벤트 대비 가속권 보유 현황을 조사하는 페이지입니다"
>
  <div class="sk-page" id="sk-page">
    <!-- 화면 가운데 토스트 (클립보드 복사 피드백) — 타일매치 .tm-toast 패턴 동일. -->
    <div class="sk-toast" id="sk-toast" role="status" aria-live="polite"></div>

    <!-- 필독 안내문 트리거 — 클릭 시 별도 다이얼로그. 강조 톤 (빨강/주황 + pulse) 으로 주의 환기. -->
    <button type="button" class="sk-notice-trigger" id="sk-notice-trigger">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10"></circle>
        <line x1="12" y1="16" x2="12" y2="12"></line>
        <line x1="12" y1="8" x2="12.01" y2="8"></line>
      </svg>
      <span data-i18n="survey.kvk.notice.triggerLabel">필독 안내문</span>
    </button>

    <!-- 필독 안내문 다이얼로그 — 트리거 클릭 시 노출. 닫기 버튼 / ESC / backdrop 으로 닫힘. -->
    <dialog class="sk-dialog sk-notice-dialog" id="sk-notice-dialog" aria-labelledby="sk-notice-title">
      <div class="sk-dialog-card">
        <header class="sk-dialog-head">
          <strong id="sk-notice-title" data-i18n="survey.kvk.notice.triggerLabel">필독 안내문</strong>
          <button
            type="button"
            class="sk-dialog-close"
            id="sk-notice-close"
            aria-label="Close"
          >&times;</button>
        </header>
        <div class="sk-dialog-body">
          <section class="sk-notice-section">
            <h4 class="sk-notice-section-title" data-i18n="survey.kvk.notice.signup.title">설문 등록</h4>
            <ul class="sk-notice-list">
              <li data-i18n-html="survey.kvk.notice.signup.deadline">마감: <strong>UTC 6월 14일 00:00</strong></li>
              <li data-i18n-html="survey.kvk.notice.signup.eligibility">자격: <strong>TC 26 이상</strong></li>
            </ul>
          </section>

          <section class="sk-notice-section">
            <h4 class="sk-notice-section-title" data-i18n="survey.kvk.notice.ranking.title">순위 기준</h4>
            <p class="sk-notice-lead" data-i18n="survey.kvk.notice.ranking.intro">
              보유 가속권의 예측 점수로 순위 결정.
            </p>
            <ul class="sk-notice-list">
              <li data-i18n-html="survey.kvk.notice.ranking.tier1"><strong>1순위</strong>: 상위 48위 + 이미지 인증</li>
              <li data-i18n-html="survey.kvk.notice.ranking.tier2"><strong>2순위</strong>: 이미지 인증</li>
            </ul>
            <p class="sk-notice-example" data-i18n="survey.kvk.notice.ranking.example">
              예) 46~48위(미인증)보다 49위(인증)가 우선.
            </p>
          </section>

          <section class="sk-notice-section">
            <h4 class="sk-notice-section-title" data-i18n="survey.kvk.notice.reward.title">순위 보상</h4>
            <p class="sk-notice-lead" data-i18n-html="survey.kvk.notice.reward.body">
              상위 48명에게 <strong>1일차(건설) / 4일차(병사)</strong> 국왕스킬 30분씩 순차 부여.
            </p>
          </section>

          <section class="sk-notice-section">
            <h4 class="sk-notice-section-title" data-i18n="survey.kvk.notice.schedule.title">시간 예약</h4>
            <ul class="sk-notice-list">
              <li data-i18n-html="survey.kvk.notice.schedule.body1">설문 종료 후 <strong>버프 예약 페이지</strong>에서 사용 시간 직접 선택.</li>
              <li data-i18n="survey.kvk.notice.schedule.body2">순위 1위부터 순차 진행.</li>
            </ul>
          </section>

          <section class="sk-notice-section">
            <h4 class="sk-notice-section-title" data-i18n="survey.kvk.notice.caution.title">주의사항</h4>
            <ul class="sk-notice-list">
              <li data-i18n="survey.kvk.notice.caution.body1">가속권은 최대한 KvK 점수에 투입해 주세요.</li>
              <li data-i18n-html="survey.kvk.notice.caution.body2"><strong class="sk-notice-warn">허위 제출 / 예측 점수 미달 시 패널티</strong>가 부과됩니다.</li>
            </ul>
          </section>
        </div>
      </div>
    </dialog>

    <!-- (A) 시작 다이얼로그 — ID 입력 + 본인 확인 + PIN -->
    <dialog class="sk-dialog" id="sk-auth-dialog" aria-labelledby="sk-auth-title">
      <div class="sk-dialog-card">
        <header class="sk-dialog-head">
          <strong id="sk-auth-title" data-i18n="survey.kvk.auth.title">시작하기</strong>
          <button
            type="button"
            class="sk-dialog-close"
            id="sk-auth-close"
            aria-label="Close"
          >&times;</button>
        </header>
        <div class="sk-dialog-body">
          <!-- Step 1: ID 입력 -->
          <div class="sk-step" id="sk-step-id">
            <label
              for="sk-id-input"
              class="sk-label"
              data-i18n="survey.kvk.auth.idLabel"
            >킹샷 ID</label>
            <div class="sk-input-row">
              <input
                type="text"
                id="sk-id-input"
                inputmode="numeric"
                autocomplete="off"
                placeholder="예: 270680423"
                data-i18n-attr-placeholder="survey.kvk.auth.idPlaceholder"
              />
              <button
                type="button"
                class="sk-btn sk-btn-primary"
                id="sk-id-search"
                data-i18n="survey.kvk.auth.searchButton"
              >조회</button>
            </div>
            <div class="sk-status" id="sk-id-status" role="status" aria-live="polite"></div>
          </div>

          <!-- Step "blocked": TC 레벨 26 미만 — 등록 불가 안내 후 닫기 -->
          <div class="sk-step sk-step-blocked" id="sk-step-blocked" hidden>
            <div class="sk-blocked-icon">⛔</div>
            <h4 class="sk-blocked-title" data-i18n="survey.kvk.blocked.title">
              설문에 참여할 수 없는 대상입니다
            </h4>
            <p class="sk-blocked-body" data-i18n-html="survey.kvk.blocked.body">
              TC 레벨 <strong>26 이상</strong> 사용자만 등록 가능합니다.
            </p>
            <p class="sk-blocked-current" id="sk-blocked-current">현재 레벨: TC -</p>
            <div class="sk-dialog-actions">
              <button
                type="button"
                class="sk-btn sk-btn-primary"
                id="sk-blocked-close"
                data-i18n="survey.kvk.blocked.closeButton"
              >닫기</button>
            </div>
          </div>

          <!-- Step 2: 본인 확인 -->
          <div class="sk-step" id="sk-step-confirm" hidden>
            <div class="sk-player-card" id="sk-player-card">
              <div class="sk-player-photo-wrap">
                <div class="sk-player-photo-empty" id="sk-player-photo-empty">?</div>
                <img class="sk-player-photo" id="sk-player-photo" src="" alt="" hidden />
              </div>
              <div class="sk-player-meta">
                <div class="sk-player-name" id="sk-player-name">-</div>
                <div class="sk-player-id" id="sk-player-id">-</div>
              </div>
            </div>
            <p class="sk-help" data-i18n="survey.kvk.auth.confirmHelp">
              본인이 맞으면 PIN 4자리를 입력해 주세요. (신규는 새 PIN 설정, 기존이면 등록한 PIN)
            </p>
            <div class="sk-pin-header">
              <span class="sk-label" data-i18n="survey.kvk.auth.pinLabel">PIN 4자리</span>
              <span class="sk-pin-hint" id="sk-pin-hint" data-i18n="survey.kvk.auth.pinHintNew">
                신규 등록 — 새 PIN 으로 사용됩니다
              </span>
            </div>
            <div class="sk-pin-wrap" id="sk-pin-wrap">
              <!-- 보이지 않는 단일 input + 위에 겹쳐진 4개의 box (tile-match-auth 패턴 차용).
                   input 의 value 길이에 따라 box 채움 표시. -->
              <input
                class="sk-pin-input"
                id="sk-pin-input"
                type="text"
                inputmode="numeric"
                pattern="[0-9]*"
                maxlength="4"
                autocomplete="off"
                autocapitalize="off"
                autocorrect="off"
                spellcheck="false"
                aria-label="PIN 4자리 입력"
                data-i18n-attr-aria-label="auth.pinInputAria"
              />
              <div class="sk-pin-boxes" id="sk-pin-boxes" aria-hidden="true">
                <div class="sk-pin-box"></div>
                <div class="sk-pin-box"></div>
                <div class="sk-pin-box"></div>
                <div class="sk-pin-box"></div>
              </div>
            </div>
            <div class="sk-status" id="sk-pin-status" role="status" aria-live="polite"></div>
            <div class="sk-dialog-actions">
              <!-- [확인] 버튼 제거 — 4자리 입력 완성 시 자동 호출 + Enter 키도 같은 동작. -->
              <button
                type="button"
                class="sk-btn sk-btn-secondary"
                id="sk-pin-back"
                data-i18n="common.back"
              >뒤로</button>
            </div>
          </div>
        </div>
      </div>
    </dialog>

    <!-- (B) 폼 다이얼로그 (PIN 인증 후 또는 로그인된 사용자가 [등록/수정] 클릭 시 노출) -->
    <dialog class="sk-dialog sk-form-dialog" id="sk-form-dialog" aria-labelledby="sk-form-title">
      <div class="sk-dialog-card">
        <header class="sk-dialog-head">
          <strong id="sk-form-title" data-i18n="survey.kvk.form.dialogTitle"
            >내 정보 등록 / 수정</strong
          >
          <button
            type="button"
            class="sk-dialog-close"
            id="sk-form-close"
            aria-label="Close"
          >&times;</button>
        </header>
        <div class="sk-dialog-body">
          <div class="sk-player-card sk-player-card-compact" id="sk-form-player">
            <div class="sk-player-photo-wrap">
              <div class="sk-player-photo-empty" id="sk-form-photo-empty">?</div>
              <img class="sk-player-photo" id="sk-form-photo" src="" alt="" hidden />
            </div>
            <div class="sk-player-meta">
              <div class="sk-player-name" id="sk-form-name">-</div>
              <div class="sk-player-id" id="sk-form-id">-</div>
            </div>
          </div>
          <p class="sk-help">
            <span data-i18n="survey.kvk.form.help"
              >게임 내 가속권 현황 상태에서 분 단위로 설정한 값을 입력해주세요</span
            >
            <button
              type="button"
              class="sk-help-image-trigger"
              id="sk-help-image-trigger"
              data-i18n="survey.kvk.form.helpImageLink"
            >이미지 보기</button>
          </p>
          <div class="sk-form-warn" role="note">
            <span class="sk-form-warn-icon" aria-hidden="true">⚠️</span>
            <span data-i18n="survey.kvk.form.warn"
              >허위 정보를 제출한 경우, KvK 종료 후 패널티가 부과됩니다.</span
            >
          </div>
          <div class="sk-form-rows">
            <!-- 가속권 3개 — input.num 자체가 컨테이너, prefix(좌) + unit(우) absolute overlay -->
            <div class="sk-form-row">
              <span class="sk-form-row-prefix">
                <span class="sk-form-row-prefix-emoji" aria-hidden="true">⭐</span>
                <span data-i18n="survey.kvk.list.thead.general">공용</span>
              </span>
              <input
                type="text"
                id="sk-input-general"
                class="sk-form-row-input"
                inputmode="numeric"
                autocomplete="off"
                placeholder="예: 16,767"
                data-i18n-attr-placeholder="survey.kvk.form.placeholderGeneral"
              />
              <span class="sk-form-row-unit" data-i18n="survey.kvk.form.unit">분</span>
            </div>
            <div class="sk-form-row">
              <span class="sk-form-row-prefix">
                <span class="sk-form-row-prefix-emoji" aria-hidden="true">🛡️</span>
                <span data-i18n="survey.kvk.list.thead.training">병사</span>
              </span>
              <input
                type="text"
                id="sk-input-training"
                class="sk-form-row-input"
                inputmode="numeric"
                autocomplete="off"
                placeholder="예: 11,943"
                data-i18n-attr-placeholder="survey.kvk.form.placeholderTraining"
              />
              <span class="sk-form-row-unit" data-i18n="survey.kvk.form.unit">분</span>
            </div>
            <div class="sk-form-row">
              <span class="sk-form-row-prefix">
                <span class="sk-form-row-prefix-emoji" aria-hidden="true">🔨</span>
                <span data-i18n="survey.kvk.list.thead.construction">건설</span>
              </span>
              <input
                type="text"
                id="sk-input-construction"
                class="sk-form-row-input"
                inputmode="numeric"
                autocomplete="off"
                placeholder="예: 11,709"
                data-i18n-attr-placeholder="survey.kvk.form.placeholderConstruction"
              />
              <span class="sk-form-row-unit" data-i18n="survey.kvk.form.unit">분</span>
            </div>
            <!-- 인증샷 row — grid 2칼럼 [prefix | content].
                 content 영역은 has-image 클래스에 따라 [파일 선택 라벨] 또는 [thumb+name+제거] 토글. -->
            <div class="sk-form-row sk-form-row-image" id="sk-form-row-image">
              <span class="sk-form-row-prefix">
                <span class="sk-form-row-prefix-emoji" aria-hidden="true">📎</span>
                <span data-i18n="survey.kvk.form.evidenceLabel">인증샷</span>
              </span>
              <div class="sk-evidence-content">
                <!-- empty 상태 -->
                <label class="sk-evidence-pick" for="sk-input-evidence">
                  <span data-i18n="survey.kvk.form.evidencePickButton">파일 선택</span>
                </label>
                <!-- selected 상태 -->
                <div class="sk-evidence-attached">
                  <div class="sk-evidence-thumb">
                    <img id="sk-evidence-thumb-img" alt="" />
                  </div>
                  <span class="sk-evidence-name" id="sk-evidence-name"></span>
                  <button
                    type="button"
                    class="sk-evidence-remove"
                    id="sk-evidence-remove"
                    data-i18n="survey.kvk.form.evidenceRemoveButton"
                  >제거</button>
                </div>
              </div>
            </div>
            <!-- file input — visually hidden 으로 row 밖 배치. 라벨이 for 로 trigger. -->
            <input
              type="file"
              id="sk-input-evidence"
              accept="image/*"
              class="sk-visually-hidden"
            />
          </div>
          <p
            class="sk-evidence-hint"
            data-i18n="survey.kvk.form.evidenceHint"
          >1080px / WebP / 최대 ~150 KB 로 자동 압축됩니다.</p>
          <div class="sk-status" id="sk-form-status" role="status" aria-live="polite"></div>
          <div class="sk-form-actions">
            <!-- 삭제: 수정 모드일 때만 노출 (JS 가 enterFormMode 에서 hidden 토글). 좌측 끝. -->
            <button
              type="button"
              class="sk-btn sk-btn-danger"
              id="sk-form-delete"
              hidden
              data-i18n="survey.kvk.form.deleteButton"
            >삭제</button>
            <!-- 취소 + 저장 — 우측 페어 (Cancel margin-left: auto 로 우측 push) -->
            <button
              type="button"
              class="sk-btn sk-btn-secondary"
              id="sk-form-cancel"
              data-i18n="survey.kvk.form.cancelButton"
            >취소</button>
            <button
              type="button"
              class="sk-btn sk-btn-primary"
              id="sk-form-save"
              data-i18n="common.save"
            >저장</button>
          </div>
        </div>
      </div>
    </dialog>

    <!-- (C) 목록 영역 — 인증 전엔 잠금 placeholder, 인증 후 .sk-page.is-unlocked 로 노출 -->
    <section class="sk-list-section">
      <header class="sk-list-head">
        <h3 data-i18n="survey.kvk.list.heading">제출 현황</h3>
        <div class="sk-list-toolbar">
          <span class="sk-list-count" id="sk-list-count"></span>
          <input
            type="search"
            class="sk-list-search"
            id="sk-list-search"
            autocomplete="off"
            placeholder="닉네임 또는 ID 검색"
            data-i18n-attr-placeholder="survey.kvk.list.searchPlaceholder"
            aria-label="닉네임 또는 ID 검색"
            data-i18n-attr-aria-label="survey.kvk.list.searchPlaceholder"
          />
          <button
            type="button"
            class="sk-icon-btn"
            id="sk-list-refresh"
            aria-label="새로고침"
            data-i18n-attr-aria-label="common.refresh"
            title="새로고침"
            data-i18n-attr-title="common.refresh"
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <polyline points="23 4 23 10 17 10"></polyline>
              <polyline points="1 20 1 14 7 14"></polyline>
              <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path>
            </svg>
          </button>
          <!-- 액션 버튼 묶음 — 세 버튼이 한 wrapper 에 들어가 hidden 토글 시 toolbar 의 다른
               자식 (count, refresh, search) 위치가 흔들리지 않음.
               세 버튼 모두 초기 hidden — survey-kvk.ts 의 syncListButtons() 가 deadline + auth + admin
               조건 보고 노출 결정. 각 버튼은 자기 트리거 함수 한 개씩만 갖고 명확히 분리됨:
                 [테스트]    (sk-list-test)  → onClickTest         admin 만 (마감 전/후 무관)
                 [버프 예약] (sk-list-buff)  → onClickBuffBooking  마감 후 모두 / admin 항상
                 [등록/수정] (sk-list-add)   → onClickRegister     마감 전만 -->
          <div class="sk-list-end-actions">
            <button
              type="button"
              class="sk-btn sk-btn-test sk-list-test"
              id="sk-list-test"
              hidden
            >
              <span data-i18n="survey.kvk.list.testButton">테스트</span>
            </button>
            <button
              type="button"
              class="sk-btn sk-btn-primary sk-list-buff"
              id="sk-list-buff"
              hidden
            >
              <span data-i18n="survey.kvk.list.buffBookingButton">버프 예약</span>
            </button>
            <button
              type="button"
              class="sk-btn sk-btn-primary sk-list-add"
              id="sk-list-add"
              hidden
            >
              <span class="sk-list-add-label" data-i18n="survey.kvk.list.addButton">등록 / 수정</span>
              <span class="sk-list-add-countdown" id="sk-list-add-countdown" aria-live="off">
                <span id="sk-list-add-countdown-text">--</span>
              </span>
            </button>
          </div>
        </div>
      </header>

      <!-- 정렬 컨트롤 바 — PC/모바일 공용. 모바일에선 이모지 안내(legend) 도 함께 노출. -->
      <div class="sk-controls">
        <div class="sk-legend">
          <span class="sk-legend-item"><span class="sk-legend-emoji">⭐</span>
            <span data-i18n="survey.kvk.list.thead.general">공용</span></span>
          <span class="sk-legend-item"><span class="sk-legend-emoji">🛡️</span>
            <span data-i18n="survey.kvk.list.thead.training">병사</span></span>
          <span class="sk-legend-item"><span class="sk-legend-emoji">🔨</span>
            <span data-i18n="survey.kvk.list.thead.construction">건설</span></span>
        </div>
        <!-- 두 그룹 좌우 분리. PC: justify-content: space-between 한 줄. 모바일: 각 그룹 flex-basis 100%
