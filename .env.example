# Supabase 클라이언트 설정 (PUBLIC_ 접두사 필수 — 클라이언트 번들에 포함됨)
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Supabase CLI 운영용 (db push, functions deploy 시 사용)
# 발급: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_...

# 빌드 타임 SSG 전용 (전략 페이지 등 service_role 필요 쿼리)
# 절대 클라이언트 번들에 포함 금지 — Astro frontmatter(---) 또는 서버 전용 모듈에서만 사용
SUPABASE_SERVICE_ROLE_KEY=eyJ...
