    </dialog>

    <!-- 슬롯 선택 confirm -->
    <dialog class="sk-buff-confirm" id="sk-buff-confirm-dialog" aria-label="시간 선택 확인">
      <div class="sk-buff-confirm-card">
        <p class="sk-buff-confirm-body">
          <strong id="sk-buff-confirm-time">00:00</strong>
          <span data-i18n="survey.kvkBuff.confirm.pickSlot">시간을 선택하시겠습니까?</span>
        </p>
        <div class="sk-buff-confirm-actions">
          <button type="button" class="sk-buff-confirm-cancel" id="sk-buff-confirm-cancel" data-i18n="survey.kvkBuff.confirm.cancel">취소</button>
          <button type="button" class="sk-buff-confirm-ok" id="sk-buff-confirm-ok" data-i18n="survey.kvkBuff.confirm.pick">선택</button>
        </div>
      </div>
    </dialog>

    <!-- [변경] — admin 이 다음 차례 사용자 지정 다이얼로그.
         사용자 목록 (#sk-buff-replace-list) 은 클라가 동적 렌더 (turn_idx 순).
         완료 슬롯 점유 사용자 + 현재 차례 본인은 disabled. -->
    <dialog class="sk-buff-replace" id="sk-buff-replace-dialog" aria-labelledby="sk-buff-replace-title">
      <div class="sk-buff-replace-card">
        <header class="sk-buff-replace-head">
          <strong id="sk-buff-replace-title" data-i18n="survey.kvkBuff.replaceTitle">차례 변경</strong>
          <button type="button" class="sk-dialog-close" id="sk-buff-replace-close" aria-label="Close">&times;</button>
        </header>
        <p class="sk-buff-replace-help" data-i18n="survey.kvkBuff.replaceHelp">
          현재 차례 사용자와 자리를 교환할 대상을 선택하세요.
        </p>
        <ul class="sk-buff-replace-list" id="sk-buff-replace-list" role="radiogroup">
          <!-- 클라가 turn_idx 순으로 채움 -->
        </ul>
        <div class="sk-buff-replace-actions">
          <button type="button" class="sk-buff-confirm-cancel" id="sk-buff-replace-cancel" data-i18n="survey.kvkBuff.confirm.cancel">취소</button>
          <button type="button" class="sk-buff-confirm-ok" id="sk-buff-replace-ok" data-i18n="survey.kvkBuff.confirm.apply" disabled>적용</button>
        </div>
      </div>
    </dialog>

    <!-- swap confirm (admin) -->
    <dialog class="sk-buff-confirm" id="sk-buff-swap-dialog" aria-label="자리 교환 확인">
      <div class="sk-buff-confirm-card">
        <p class="sk-buff-confirm-body" id="sk-buff-swap-body"></p>
        <div class="sk-buff-confirm-actions">
          <button type="button" class="sk-buff-confirm-cancel" id="sk-buff-swap-cancel" data-i18n="survey.kvkBuff.confirm.cancel">취소</button>
          <button type="button" class="sk-buff-confirm-ok" id="sk-buff-swap-ok" data-i18n="survey.kvkBuff.confirm.confirm">확인</button>
        </div>
      </div>
    </dialog>
  </div>

  <script>
    import '@/scripts/pages/survey';
    // 'app-open-auth' 는 BaseLayout 의 공용 AuthDialog 가 처리.
    // sk-auth-dialog 는 KvK 의 [등록/수정] 흐름(TC 레벨 게이트 포함)에만 사용 유지.
  </script>
</SurveyLayout>
