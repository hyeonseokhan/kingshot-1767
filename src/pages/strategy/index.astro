const detailCloseBtn   = document.getElementById('st-detail-close')!;
const detailAvEl       = document.getElementById('st-detail-av')!;
const detailNickEl     = document.getElementById('st-detail-nickname')!;
const detailIdEl       = document.getElementById('st-detail-id')!;
const detailTcEl       = document.getElementById('st-detail-tc')!;
const detailAllianceEl = document.getElementById('st-detail-alliance')!;
const detailPowerEl    = document.getElementById('st-detail-power')!;
const detailEditBtn    = document.getElementById('st-detail-edit-btn') as HTMLButtonElement;

function openDetailDialog(assignmentId: number) {
  const a = assignments.find((x) => x.id === assignmentId);
