              </div>
              <div class="sk-buff-current-completed" data-i18n="survey.kvkBuff.completed">
                모든 사용자가 시간을 선택했습니다
              </div>
              <!-- admin [예약 마감] 호출 후 노출 — .is-finalized 클래스로 CSS 분기. -->
              <div class="sk-buff-current-finalized" data-i18n="survey.kvkBuff.finalizedMsg">
                예약이 마감됐습니다
              </div>
            </section>

            <!-- 시간표 — 헤더 (KST/필터/복사) + 슬롯 목록 두 영역으로 분리. 그리드 박스 한 단위로 시각 통합. -->
            <div class="sk-buff-grid" id="sk-buff-grid">
              <header class="sk-buff-grid-head">
                <button type="button" class="sk-buff-toggle" id="sk-buff-tz-toggle">KST → UTC</button>
                <button type="button" class="sk-buff-toggle" id="sk-buff-filter-toggle" data-i18n="survey.kvkBuff.filterAvailable">남은 자리</button>
                <button type="button" class="sk-buff-toggle" id="sk-buff-copy-toggle" data-i18n="survey.kvkBuff.copyButton">복사하기</button>
              </header>
              <div class="sk-buff-grid-list" id="sk-buff-grid-list"></div>
            </div>

            <div class="sk-buff-locked" id="sk-buff-locked" hidden>
              <div class="sk-buff-locked-title" data-i18n="survey.kvkBuff.locked.title">🔒 아직 예약을 시작할 수 없어요</div>
              <p class="sk-buff-locked-body" id="sk-buff-locked-body" data-i18n="survey.kvkBuff.locked.bodyBeforeDeadline">
                관리자가 [예약 시작] 을 누르면 진행됩니다.
              </p>
            </div>
          </div>
        </div>
      </div>
    </dialog>

