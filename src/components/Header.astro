---
// 통합 상단 헤더 — KvK 설문 / 캐슬 전투 두 서비스를 탭으로 전환.
// BaseLayout 에서 사용. 서비스별 layout(SurveyLayout/CastleBattleLayout) 은 Header 를 직접 import 하지 않고
// BaseLayout 을 감싸 사용한다.
import LangSwitcher from '@/components/LangSwitcher.astro';
import { tabs, findActiveTab } from '@/data/navigation';

const activeTab = findActiveTab(Astro.url.pathname);
---

<header class="app-header">
  <div class="app-header-inner">
    <a class="app-brand" href="/" aria-label="1767 서버 — 홈으로">
      <img src="/logo.png" alt="PNX" width="28" height="28" decoding="async" />
      <span class="app-brand-text" data-i18n="header.title">1767 서버</span>
    </a>

    <nav class="app-nav" aria-label="서비스 메뉴">
      {tabs.map((tab) => (
        <a
          href={tab.path}
          class:list={['app-nav-tab', { 'is-active': activeTab?.id === tab.id }]}
          data-i18n={tab.titleKey}
          aria-current={activeTab?.id === tab.id ? 'page' : undefined}
        >
          {tab.title}
        </a>
      ))}
    </nav>

    <div class="app-header-actions">
      <slot name="header-actions" />
      <LangSwitcher />
    </div>
  </div>
</header>

<style>
  .app-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.88);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--brand-border);
    box-shadow: 0 1px 0 rgba(15, 23, 42, 0.03);
    height: var(--header-h);
    flex-shrink: 0;
  }
  .app-header-inner {
    max-width: 1400px;
    height: 100%;
    margin: 0 auto;
    padding: 0 16px;
    display: flex;
    align-items: center;
    gap: 24px;
  }
  .app-brand {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    flex-shrink: 0;
  }
  .app-brand img {
    display: block;
    width: 28px;
    height: 28px;
    flex-shrink: 0;
  }
  .app-brand-text {
    font-size: 14px;
    font-weight: 800;
    color: var(--brand-text);
    letter-spacing: -0.01em;
    transition: color 0.15s;
  }
  .app-brand:hover .app-brand-text { color: var(--brand-accent); }

  .app-nav {
    display: flex;
    gap: 4px;
    flex: 1;
    min-width: 0;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .app-nav::-webkit-scrollbar { display: none; }

  .app-nav-tab {
    display: inline-flex;
    align-items: center;
    padding: 6px 12px;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 600;
    color: var(--brand-text-dim);
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s, color 0.15s;
  }
  .app-nav-tab:hover {
    background: rgba(15, 23, 42, 0.05);
    color: var(--brand-text);
    text-decoration: none;
  }
  .app-nav-tab.is-active {
    color: var(--brand-accent);
    background: rgba(124, 58, 237, 0.10);
  }

  .app-header-actions {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
  }

  @media (max-width: 600px) {
    .app-header-inner {
      gap: 12px;
      padding: 0 10px;
    }
    .app-brand {
      font-size: 13px;
    }
    .app-nav-tab {
      padding: 5px 10px;
      font-size: 12.5px;
    }
  }
</style>
