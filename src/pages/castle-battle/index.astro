---
// 캐슬 전투 — 메인 페이지 (실 DB 조회).
//
// Phase 1: 조회 전용 — cb_* 테이블에서 회차/거점/후보/표 가져와 카드 렌더.
// 다이얼로그/투표 액션은 후속 Phase 에서.
//
// 데이터 흐름:
//   1) getActiveRound() — 현재 활성 회차 (status != archived)
//   2) (선택) AUTH_KEY 에서 내 kingshot_id 확인 → my_vote / is_mine 표시
//   3) getTargetsWithCandidates(round.id, myId) — 거점 + 후보 + 표 집계
//   4) Battlefield 컴포넌트 에 전달
//
// 회차 미개최 시: 안내 화면.

import CastleBattleLayout from '@/layouts/CastleBattleLayout.astro';
import RoundHero from '@/components/castle-battle/RoundHero.astro';
import Battlefield from '@/components/castle-battle/Battlefield.astro';
import TargetDetailDialog from '@/components/castle-battle/TargetDetailDialog.astro';
import { getActiveRound, getTargetsWithCandidates } from '@/lib/castle-battle/queries';
import '@/styles/castle-battle.css';

const round = await getActiveRound();
const targets = round ? await getTargetsWithCandidates(round.id, null) : [];
const totalVotes = targets.reduce((s, t) => s + t.total_votes, 0);
---

<CastleBattleLayout
  title="캐슬 전투 — 1767 서버 허브"
  description="캐슬 전투 회차별 거점 점령 집결자 예측 투표"
>
  {/* 관리자 도구 팝오버 — header-actions slot 주입. SSR 기본 hidden → 클라이언트가 is_admin 확인 후 노출. */}
  <details class="cb-admin-pop" id="cb-admin-pop-root" slot="header-actions" hidden>
    <summary>🛠 관리자 도구</summary>
    <div class="cb-admin-pop-panel">
      <div class="cb-admin-pop-head">🛠 관리자 도구</div>
      <div class="cb-admin-pop-body">

        {/* 회차 관리 */}
        <div class="cb-admin-group">
          <div class="cb-admin-group-label">회차 관리</div>
          <div class="cb-admin-group-actions">
            <button class="cb-btn cb-btn-sm" id="cb-admin-new-round-btn">＋ 신규 회차 등록</button>
          </div>
        </div>

        {/* 진행 중인 회차가 있을 때만 표시되는 영역 */}
        <div class="cb-admin-group" id="cb-admin-active-group" hidden>
          <div class="cb-admin-group-label">현재 회차</div>
          <div class="cb-admin-group-actions">
            <button class="cb-btn cb-btn-sm" id="cb-admin-voting-btn">투표 시작</button>
            <button class="cb-btn cb-btn-sm" id="cb-admin-close-btn">투표 마감</button>
            <button class="cb-btn cb-btn-secondary cb-btn-sm" id="cb-admin-next-btn">다음 단계로</button>
          </div>
          <div class="cb-admin-round-status" id="cb-admin-round-status"></div>
        </div>

      </div>
    </div>
  </details>

  {round ? (
    <>
      <RoundHero round={round} roundIndex={round.id} totalVotes={totalVotes} />
      <Battlefield targets={targets} />
      <TargetDetailDialog targets={targets} />
    </>
  ) : (
    <section class="cb-empty-round">
      <div class="cb-empty-icon">🏰</div>
      <h2 class="cb-empty-title">진행 중인 회차가 없습니다</h2>
      <p class="cb-empty-body">
        다음 캐슬 전투 회차가 개최되면 이 곳에서 거점별 집결자 예측 투표가 시작됩니다.
      </p>
    </section>
  )}

  {/* 신규 회차 등록 다이얼로그 */}
  <dialog class="cb-nr-dlg" id="cb-nr-dlg">
    <div class="cb-nr-inner">

      <div class="cb-nr-header">
        <h2 class="cb-nr-title">신규 회차 등록</h2>
      </div>

      <div class="cb-nr-body">

        {/* 기본 정보 */}
        <div class="cb-nr-section">
          <div class="cb-nr-field">
            <label class="cb-nr-label" for="cb-nr-date-input">
              이벤트 시작 일시 <span class="cb-nr-label-note">KST 기준</span>
            </label>
            <input class="cb-nr-input" id="cb-nr-date-input" type="datetime-local" />
          </div>
        </div>

        {/* 거점 설정 */}
        <div class="cb-nr-section">
          <div class="cb-nr-section-title">거점 설정</div>
          <div class="cb-nr-section-desc">각 거점의 집결전 여부와 집결자 후보를 설정하세요.</div>

          <div class="cb-nr-slots" id="cb-nr-slots">
            {/* JavaScript 가 동적으로 렌더 */}
          </div>
        </div>

      </div>

      <div class="cb-nr-footer">
        <div class="cb-nr-error" id="cb-nr-error"></div>
        <div class="cb-nr-actions">
          <button class="cb-btn cb-btn-secondary" id="cb-nr-cancel" type="button">취소</button>
          <button class="cb-btn" id="cb-nr-submit" type="button">회차 등록</button>
        </div>
      </div>

    </div>
  </dialog>

</CastleBattleLayout>

<script>
  // ─── 관리자 팝오버 게이트 ────────────────────────────────────
  const AUTH_KEY = 'pnx-mb-auth-v1';
  function checkAdmin(): boolean {
    try {
      const obj = JSON.parse(localStorage.getItem(AUTH_KEY) ?? '');
      return obj?.record?.is_admin === true;
    } catch { return false; }
  }
  function getAuthRecord(): { kingshot_id: string; is_admin: boolean } | null {
    try {
      const obj = JSON.parse(localStorage.getItem(AUTH_KEY) ?? '');
      if (!obj?.record?.kingshot_id) return null;
      return obj.record;
    } catch { return null; }
  }

  function syncAdminGate(): void {
    const root = document.getElementById('cb-admin-pop-root');
    if (!root) return;
    root.hidden = !checkAdmin();
  }
  document.addEventListener('app-auth-changed', syncAdminGate);
  window.addEventListener('storage', (e) => { if (e.key === AUTH_KEY) syncAdminGate(); });
  syncAdminGate();

  // 팝오버 외부 클릭 시 닫기
  document.addEventListener('click', (e) => {
    const pop = document.getElementById('cb-admin-pop-root') as HTMLDetailsElement | null;
    if (!pop || !pop.open) return;
    if (!pop.contains(e.target as Node)) pop.open = false;
  });

  // ─── 신규 회차 다이얼로그 ────────────────────────────────────

  import { SUPABASE_URL, SUPABASE_ANON_KEY } from '@/lib/shared/supabase';

  const FN_URL = SUPABASE_URL + '/functions/v1/castle-battle';

  const SLOTS = [
    { slot: 'castle',        label: '캐슬',     defaultOpen: true },
    { slot: 'turret_north',  label: '북쪽 포탑', defaultOpen: false },
    { slot: 'turret_east',   label: '동쪽 포탑', defaultOpen: true },
    { slot: 'turret_south',  label: '남쪽 포탑', defaultOpen: true },
    { slot: 'turret_west',   label: '서쪽 포탑', defaultOpen: true },
  ] as const;

  async function callFn(body: Record<string, unknown>): Promise<any> {
    const auth = getAuthRecord();
    const payload = auth ? { player_id: auth.kingshot_id, ...body } : body;
    const res = await fetch(FN_URL, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        apikey: SUPABASE_ANON_KEY,
        Authorization: 'Bearer ' + SUPABASE_ANON_KEY,
      },
      body: JSON.stringify(payload),
    });
    return res.json();
  }

  // PIN 입력 다이얼로그 — 관리자 액션마다 PIN 재확인
  function promptPin(): Promise<string | null> {
    return new Promise((resolve) => {
      const pin = window.prompt('관리자 PIN 4자리를 입력하세요.');
      resolve(pin?.trim() || null);
    });
  }

  // ─── 슬롯 렌더 ───────────────────────────────────────────────

  function esc(str: string): string {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function buildSlotCard(slotDef: typeof SLOTS[number]): HTMLElement {
    const card = document.createElement('div');
    card.className = 'cb-nr-slot';
    card.dataset.slot = slotDef.slot;

    card.innerHTML = `
      <div class="cb-nr-slot-header">
        <span class="cb-nr-slot-label">${slotDef.label}</span>
        <label class="cb-nr-slot-toggle">
          <input type="checkbox" class="cb-nr-open-chk" ${slotDef.defaultOpen ? 'checked' : ''}>
          <span>투표 진행</span>
        </label>
      </div>
      <div class="cb-nr-cands ${slotDef.defaultOpen ? '' : 'is-hidden'}">
        <div class="cb-nr-badge-list"></div>
        <div class="cb-nr-form">
          <div class="cb-nr-form-inputs">
            <input class="cb-nr-input cb-nr-f-tag" type="text" placeholder="연맹 (PNX)" maxlength="20" />
            <input class="cb-nr-input cb-nr-f-ksid" type="tel" placeholder="킹샷 ID" maxlength="15" pattern="[0-9]*" />
            <button class="cb-nr-lookup-btn" type="button">조회</button>
          </div>
          <div class="cb-nr-form-preview" hidden>
            <div class="cb-nr-preview-row">
              <div class="cb-nr-badge">
                <span class="cb-nr-badge-avatar">
                  <img class="cb-nr-badge-img" alt="" hidden />
                  <span class="cb-nr-badge-initial"></span>
                </span>
                <span class="cb-nr-badge-nick"></span>
              </div>
              <button class="cb-nr-add-btn" type="button">후보 등록</button>
            </div>
          </div>
          <span class="cb-nr-lookup-err"></span>
        </div>
      </div>
    `;

    const chk = card.querySelector('.cb-nr-open-chk') as HTMLInputElement;
    const cands = card.querySelector('.cb-nr-cands') as HTMLElement;
    chk.addEventListener('change', () => cands.classList.toggle('is-hidden', !chk.checked));

    const tagInput = card.querySelector('.cb-nr-f-tag') as HTMLInputElement;
    const ksidInput = card.querySelector('.cb-nr-f-ksid') as HTMLInputElement;
    const lookupBtn = card.querySelector('.cb-nr-lookup-btn') as HTMLButtonElement;
    const previewEl = card.querySelector('.cb-nr-form-preview') as HTMLElement;
    const badgeImg = card.querySelector('.cb-nr-badge-img') as HTMLImageElement;
    const badgeInitial = card.querySelector('.cb-nr-badge-initial') as HTMLElement;
    const badgeNick = card.querySelector('.cb-nr-badge-nick') as HTMLElement;
    const lookupErr = card.querySelector('.cb-nr-lookup-err') as HTMLElement;
    const addBtn = card.querySelector('.cb-nr-add-btn') as HTMLButtonElement;
    const badgeList = card.querySelector('.cb-nr-badge-list') as HTMLElement;

    let fetched: { nickname: string; profile_photo: string } | null = null;

    // ─ 조회 ─
    lookupBtn.addEventListener('click', async () => {
      const ksid = ksidInput.value.trim();
      if (!/^\d{4,15}$/.test(ksid)) { ksidInput.focus(); return; }
      lookupBtn.disabled = true;
      lookupBtn.textContent = '...';
      fetched = null;
      previewEl.hidden = true;
      lookupErr.textContent = '';

      try {
        const res = await callFn({ action: 'lookup-player', kingshot_id: ksid });
        if (res.ok) {
          fetched = { nickname: res.nickname ?? '', profile_photo: res.profile_photo ?? '' };
          if (fetched.profile_photo) {
            badgeImg.src = fetched.profile_photo;
            badgeImg.hidden = false;
            badgeInitial.hidden = true;
          } else {
            badgeImg.hidden = true;
            badgeInitial.textContent = (fetched.nickname.charAt(0) || '?').toUpperCase();
            (badgeInitial as HTMLElement).hidden = false;
          }
          badgeNick.textContent = fetched.nickname;
          previewEl.hidden = false;
          lookupBtn.textContent = '재조회';
        } else {
          lookupErr.textContent = '플레이어를 찾을 수 없습니다';
          lookupBtn.textContent = '조회';
        }
      } catch {
        lookupBtn.textContent = '조회';
      } finally {
        lookupBtn.disabled = false;
      }
    });

    // ─ 후보 등록 ─
    addBtn.addEventListener('click', () => {
      const tag = tagInput.value.trim();
      if (!tag) { tagInput.focus(); return; }
      if (!fetched) return;

      const ksid = ksidInput.value.trim();
      const photoSrc = fetched.profile_photo;
      const nick = fetched.nickname;

      const item = document.createElement('div');
      item.className = 'cb-nr-cand-badge';
      item.dataset.tag = tag;
      item.dataset.nick = nick;
      item.dataset.ksid = ksid;
      item.dataset.photo = photoSrc;

      const avatarHtml = photoSrc
        ? `<img class="cb-nr-badge-img" src="${esc(photoSrc)}" alt="" />`
        : `<span class="cb-nr-badge-initial">${esc(nick.charAt(0).toUpperCase() || '?')}</span>`;

      item.innerHTML = `
        <span class="cb-nr-badge-avatar">${avatarHtml}</span>
        <span class="cb-nr-badge-tag">${esc(tag)}</span>
        <span class="cb-nr-badge-nick">${esc(nick)}</span>
        <button class="cb-nr-badge-remove" type="button" title="제거">✕</button>
      `;
      item.querySelector('.cb-nr-badge-remove')!.addEventListener('click', () => item.remove());
      badgeList.appendChild(item);

      // 폼 초기화
      tagInput.value = '';
      ksidInput.value = '';
      fetched = null;
      previewEl.hidden = true;
      lookupBtn.textContent = '조회';
      tagInput.focus();
    });

    return card;
  }

  // ─── 다이얼로그 열기/닫기 ────────────────────────────────────

  function todayDatetimeLocal(): string {
    const d = new Date();
    d.setMinutes(0, 0, 0);
    const pad = (n: number) => String(n).padStart(2, '0');
    return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}T${pad(d.getHours())}:00`;
  }

  function todayTitle(): string {
    const d = new Date();
    const pad = (n: number) => String(n).padStart(2, '0');
    return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())} 캐슬 전투`;
  }

  function openNewRoundDlg(): void {
    const dlg = document.getElementById('cb-nr-dlg') as HTMLDialogElement;
    const dateInput = document.getElementById('cb-nr-date-input') as HTMLInputElement;
    const slotsEl = document.getElementById('cb-nr-slots') as HTMLElement;
    const errEl = document.getElementById('cb-nr-error') as HTMLElement;

    // 초기화
    dateInput.value = todayDatetimeLocal();
    errEl.textContent = '';
    slotsEl.innerHTML = '';
    for (const s of SLOTS) slotsEl.appendChild(buildSlotCard(s));

    dlg.showModal();

    // 팝오버 닫기
    const pop = document.getElementById('cb-admin-pop-root') as HTMLDetailsElement | null;
    if (pop) pop.open = false;
  }

  function closeNewRoundDlg(): void {
    const dlg = document.getElementById('cb-nr-dlg') as HTMLDialogElement;
    if (dlg.open) dlg.close();
  }

  // ─── 회차 등록 제출 ──────────────────────────────────────────

  async function submitNewRound(): Promise<void> {
    const auth = getAuthRecord();
    if (!auth) { alert('로그인이 필요합니다.'); return; }

    const dateVal = (document.getElementById('cb-nr-date-input') as HTMLInputElement).value;
    const errEl = document.getElementById('cb-nr-error') as HTMLElement;
    const submitBtn = document.getElementById('cb-nr-submit') as HTMLButtonElement;

    if (!dateVal) { errEl.textContent = '이벤트 시작 일시를 선택해 주세요.'; return; }

    const pin = await promptPin();
    if (!pin || !/^\d{4}$/.test(pin)) { errEl.textContent = 'PIN 4자리를 입력해 주세요.'; return; }

    // 거점 데이터 수집
    type Candidate = { alliance_tag: string; rallier_nickname: string; kingshot_id?: string; profile_photo?: string };
    const slotsData: Array<{ slot: string; is_open: boolean; candidates: Candidate[] }> = [];

    let hasError = false;
    document.querySelectorAll<HTMLElement>('.cb-nr-slot').forEach((card) => {
      const slot = card.dataset.slot!;
      const isOpen = (card.querySelector('.cb-nr-open-chk') as HTMLInputElement).checked;
      const candidates: Candidate[] = [];

      if (isOpen) {
        card.querySelectorAll<HTMLElement>('.cb-nr-cand-badge').forEach((badge) => {
          candidates.push({
            alliance_tag: badge.dataset.tag!,
            rallier_nickname: badge.dataset.nick!,
            kingshot_id: badge.dataset.ksid || undefined,
            profile_photo: badge.dataset.photo || undefined,
          });
        });
      }

      slotsData.push({ slot, is_open: isOpen, candidates });
    });

    if (hasError) return;

    submitBtn.disabled = true;
    errEl.textContent = '';

    try {
      const eventStartsAt = new Date(dateVal).toISOString();
      const res = await callFn({
        action: 'admin-setup-round',
        pin,
        event_starts_at: eventStartsAt,
        targets: slotsData,
      });

      if (!res.ok) {
        const msgs: Record<string, string> = {
          not_admin: '관리자 권한이 없습니다.',
          wrong_pin: 'PIN이 일치하지 않습니다.',
          missing_field: '필수 항목이 누락되었습니다.',
          unexpected_error: '이미 진행 중인 회차가 있거나 서버 오류가 발생했습니다.',
        };
        errEl.textContent = msgs[res.error] ?? `오류: ${res.error}`;
        return;
      }

      closeNewRoundDlg();
      window.location.reload();
    } catch (err) {
      errEl.textContent = '네트워크 오류: ' + (err as Error).message;
    } finally {
      submitBtn.disabled = false;
    }
  }

  // ─── 이벤트 와이어업 ─────────────────────────────────────────

  document.getElementById('cb-admin-new-round-btn')?.addEventListener('click', openNewRoundDlg);
  document.getElementById('cb-nr-cancel')?.addEventListener('click', closeNewRoundDlg);
  document.getElementById('cb-nr-submit')?.addEventListener('click', submitNewRound);
</script>

<style is:global>
  .cb-empty-round {
    max-width: 480px;
    margin: 80px auto;
    padding: 32px 24px;
    text-align: center;
    background: var(--cb-surface);
    border: 1px solid var(--cb-border);
    border-radius: 12px;
  }
  .cb-empty-icon { font-size: 48px; margin-bottom: 12px; }
  .cb-empty-title {
    font-size: 18px; font-weight: 800;
    color: var(--cb-text); margin: 0 0 8px;
  }
  .cb-empty-body {
    font-size: 13px; color: var(--cb-text-dim);
    line-height: 1.6; margin: 0;
  }

  /* 관리자 현재 회차 상태 */
  .cb-admin-round-status {
    font-size: 11px; color: var(--cb-text-dim);
    margin-top: 4px; padding: 0 2px;
  }
</style>
