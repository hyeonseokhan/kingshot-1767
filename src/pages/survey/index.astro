                <circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21 15 16 10 5 21"/>
              </svg>
            </button>
          </div>

          <div class="sk-detail-bars">
            <!-- 단위 토글 — 시/분/초 ↔ 총 분 수. 첫 가속권 바 위쪽에 우측 정렬. -->
            <div class="sk-detail-bars-header">
              <button
