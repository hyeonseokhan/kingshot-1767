---
// 전략 페이지 — 시나리오 탭 + 70/30 레이아웃(전략 | 실시간 채팅).
//
// 데이터 흐름 (클라이언트 렌더):
//   1. 페이지 로드 → localStorage('pnx-sk-auth-v1') 확인
//   2. 미인증 → 로그인 게이트 / 인증 → strategy EF verify-access 호출
//   3. 접근 가능 → strategy_assignments anon 조회 + 시나리오 탭 렌더
//   4. strategy_admins 등록 관리자 → 편집 UI(집결장 프레임 + 집결원 등록 버튼) + D&D
//
// 채팅:
//   - 초기 80건 REST 조회 (chat-fetch) → Supabase Realtime INSERT 수신
//   - 전송: strategy EF chat-send (서버사이드 5분 레이트리밋)
//   - 클라이언트 레이트리밋: localStorage 'pnx-chat-cd' (카운트다운 UI)

import StrategyLayout from '@/layouts/StrategyLayout.astro';
import '@/styles/strategy.css';
---

<StrategyLayout
  title="캐슬 전투 전략 — 1767 서버"
  description="KvK 전략 — 시나리오별 집결장/집결원 포지션 안내 (대외비)"
>
  <!-- 인증 게이트 -->
  <div id="st-gate" class="st-gate">
    <div class="st-gate-card">
      <div class="st-gate-icon">🔒</div>
      <h2 class="st-gate-title" data-i18n="strategy.gate.title">전략 페이지 접근 제한</h2>
      <p class="st-gate-desc" id="st-gate-desc" data-i18n="strategy.gate.desc">
        1767 멤버이고 센터 레벨 26 이상인 경우에만 열람 가능합니다.
      </p>
      <button class="st-gate-btn" id="st-gate-btn" type="button" data-i18n="strategy.gate.btn">로그인</button>
      <div class="st-gate-status" id="st-gate-status" hidden></div>
    </div>
  </div>

  <!-- 메인 콘텐츠 (인증 후 노출) -->
  <div id="st-main" hidden>
    <!-- 히어로 -->
    <section class="st-hero">
      <p class="st-hero-eyebrow" data-i18n="strategy.hero.eyebrow">대외비</p>
      <h1 class="st-hero-title" data-i18n="strategy.hero.title">캐슬 전투 전략</h1>
      <p class="st-hero-desc" data-i18n="strategy.hero.desc">시나리오별 집결장 · 집결원 포지션을 확인하세요.</p>
    </section>

    <!-- 70/30 레이아웃 -->
    <div class="st-page-layout">
      <!-- 좌: 시나리오 패널 + 플로우 그리드 -->
      <div class="st-page-left">
        <!-- 시나리오 패널 (탭 + 설명 통합) -->
        <div class="st-scenario-panel">
          <div class="st-tabs-row">
          <div class="st-tabs" role="tablist" id="st-tabs">
            <button class="st-tab-btn is-active" type="button" role="tab"
              aria-selected="true" data-scenario-idx="0" data-i18n="strategy.tabs.attack">공격</button>
            <button class="st-tab-btn" type="button" role="tab"
              aria-selected="false" data-scenario-idx="1" data-i18n="strategy.tabs.defense">수비</button>
            <button class="st-tab-btn" type="button" role="tab"
              aria-selected="false" data-scenario-idx="2" data-i18n="strategy.tabs.counter">카운터</button>
          </div>
          <button type="button" id="st-refresh-btn" class="st-refresh-btn" hidden aria-label="포지션 갱신">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M23 4v6h-6"/><path d="M1 20v-6h6"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
            포지션 갱신
          </button>
          </div>
          <div class="st-scenario-desc" id="st-scenario-desc" aria-live="polite" data-i18n="strategy.scenario.attack">
            캐슬 선 공격 → 후 공격 → 카운터 순서로 진행합니다.
          </div>
        </div>

        <!-- 로딩 -->
        <div id="st-loading" class="st-loading">
          <span class="st-loading-spinner"></span>
          <span data-i18n="strategy.loading">불러오는 중…</span>
        </div>

        <!-- 플로우 그리드 (JS 렌더) -->
        <div id="st-flow-grid" class="st-flow-grid" hidden></div>
      </div>

      <!-- 우: 채팅 패널 -->
      <div class="st-page-right">
        <div class="st-chat-panel">
          <div class="st-chat-header">
            <span class="st-chat-header-title" data-i18n="strategy.chat.title">실시간 채팅</span>
            <span class="st-chat-header-sub" data-i18n="strategy.chat.sub">5분 · 1회</span>
          </div>
          <div class="st-chat-messages" id="st-chat-messages"></div>
          <!-- 미인증 안내 -->
          <div id="st-chat-notice" class="st-chat-notice" hidden data-i18n="strategy.chat.notice">
            채팅에 참여하려면 로그인이 필요합니다.
          </div>
          <!-- 입력 영역 (인증 후) -->
          <div id="st-chat-input-area" class="st-chat-input-area" hidden>
            <div class="st-chat-input-row">
              <textarea
                id="st-chat-textarea"
                class="st-chat-textarea"
                rows="1"
                maxlength="200"
                placeholder="메시지 입력…"
                data-i18n-attr-placeholder="strategy.chat.placeholder"
              ></textarea>
              <button type="button" class="st-chat-send-btn" id="st-chat-send-btn" data-i18n="strategy.chat.send">전송</button>
            </div>
            <div class="st-chat-cooldown" id="st-chat-cooldown"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- 상세보기 다이얼로그 -->
  <dialog id="st-detail-dialog" class="st-detail-dialog">
    <div class="st-detail-card">
      <header class="st-detail-head">
        <strong data-i18n="strategy.detail.title">플레이어 정보</strong>
        <button type="button" class="st-detail-close" id="st-detail-close">&times;</button>
      </header>
      <div class="st-detail-body">
        <div id="st-detail-av" class="st-detail-av"></div>
        <div id="st-detail-nickname" class="st-detail-nickname"></div>
        <div id="st-detail-id" class="st-detail-kid"></div>
        <dl class="st-detail-stats">
          <div class="st-detail-stat">
            <dt data-i18n="strategy.detail.tc">센터 레벨</dt>
            <dd id="st-detail-tc">-</dd>
          </div>
          <div class="st-detail-stat">
            <dt data-i18n="strategy.detail.alliance">연맹</dt>
            <dd id="st-detail-alliance">-</dd>
          </div>
          <div class="st-detail-stat">
            <dt data-i18n="strategy.detail.power">전투력</dt>
            <dd id="st-detail-power">-</dd>
          </div>
        </dl>
      </div>
      <footer class="st-detail-footer">
        <button type="button" class="st-detail-edit-btn" id="st-detail-edit-btn"
          data-i18n="strategy.detail.editBtn" hidden>편집</button>
      </footer>
    </div>
  </dialog>

  <!-- 편집 다이얼로그 -->
  <dialog id="st-pos-dialog" class="st-pos-dialog">
    <div class="st-pos-dialog-card">
      <header class="st-pos-dialog-head">
        <strong id="st-pos-dialog-title">포지션 편집</strong>
        <button type="button" class="st-pos-dialog-close" id="st-pos-dialog-close">&times;</button>
      </header>
      <div class="st-pos-dialog-body">
        <!-- Phase 0: 현재 배정 확인 (채워진 슬롯 클릭 시) -->
        <div id="st-pos-phase-view" class="st-pos-phase" hidden>
          <div class="st-pos-preview">
            <div class="st-pos-preview-avatar" id="st-pos-view-avatar"></div>
            <div class="st-pos-preview-info">
              <div class="st-pos-preview-name" id="st-pos-view-name">-</div>
              <div class="st-pos-preview-tc"   id="st-pos-view-tc"></div>
            </div>
          </div>
          <div class="st-pos-status" id="st-pos-view-status"></div>
          <div class="st-pos-actions">
            <button type="button" class="st-pos-btn-danger"    id="st-pos-remove-btn" data-i18n="strategy.dialog.removeBtn">포지션 비우기</button>
            <button type="button" class="st-pos-btn-secondary" id="st-pos-change-btn" data-i18n="strategy.dialog.changeBtn">변경하기</button>
          </div>
        </div>
        <!-- Phase 1: ID 입력 -->
        <div id="st-pos-phase-id" class="st-pos-phase" hidden>
          <label class="st-pos-label" data-i18n="strategy.dialog.idLabel">킹샷 ID</label>
          <div class="st-pos-input-row">
            <input
              id="st-pos-id-input"
              type="text"
              inputmode="numeric"
              autocomplete="off"
              placeholder="예: 270680423"
              data-i18n-attr-placeholder="strategy.dialog.idPlaceholder"
            />
            <button type="button" class="st-pos-btn-primary" id="st-pos-lookup-btn" data-i18n="strategy.dialog.lookupBtn">조회</button>
          </div>
          <div class="st-pos-status" id="st-pos-id-status"></div>
        </div>
        <!-- Phase 2: 미리보기 + 저장 -->
        <div id="st-pos-phase-confirm" class="st-pos-phase" hidden>
          <div class="st-pos-preview">
            <div class="st-pos-preview-avatar" id="st-pos-preview-avatar"></div>
            <div class="st-pos-preview-info">
              <div class="st-pos-preview-name" id="st-pos-preview-name">-</div>
              <div class="st-pos-preview-tc"   id="st-pos-preview-tc"></div>
            </div>
          </div>
          <div class="st-pos-status" id="st-pos-confirm-status"></div>
          <div class="st-pos-actions">
            <button type="button" class="st-pos-btn-secondary" id="st-pos-back-btn" data-i18n="strategy.dialog.backBtn">뒤로</button>
            <button type="button" class="st-pos-btn-primary"   id="st-pos-save-btn" data-i18n="strategy.dialog.saveBtn">저장</button>
          </div>
        </div>
      </div>
    </div>
  </dialog>
</StrategyLayout>

<script>
import { supabase, SUPABASE_URL, SUPABASE_ANON_KEY } from '@/lib/shared/supabase';
import { t, onLangChange } from '@/i18n';

// ── 상수 ──────────────────────────────────────────────────────────
const AUTH_KEY       = 'pnx-sk-auth-v1';
const CHAT_CD_KEY    = 'pnx-chat-cd';  // ISO 문자열: 쿨다운 종료 시각
const STRATEGY_FN    = SUPABASE_URL + '/functions/v1/strategy';
const DB_BASE        = SUPABASE_URL + '/rest/v1';
const CHAT_LIMIT_MS  = 5 * 60 * 1000;

// ── 시나리오 설정 ──────────────────────────────────────────────────
const SCENARIOS = [
  { descKey: 'strategy.scenario.attack',  columns: ['attack-pre', 'attack-post', 'attack-counter'] as const },
  { descKey: 'strategy.scenario.defense', columns: ['defense-counter'] as const },
  { descKey: 'strategy.scenario.counter', columns: ['counter-pre', 'counter-post'] as const },
];

const BADGE_CLS = ['st-badge-1', 'st-badge-2', 'st-badge-3'] as const;

// ── 타입 ──────────────────────────────────────────────────────────
interface AuthRecord {
  kingshot_id: string;
  nickname:    string;
  avatar_url?: string | null;
  is_admin?:   boolean;
}

interface Assignment {
  id:            number;
  group_id:      string;
  is_leader:     boolean;
  display_order: number;
  kingshot_id:   string | null;
  nickname:      string | null;
  avatar_url:    string | null;
  city_level:    number | null;
  power:         number | null;
  alliance_abbr: string | null;
}

interface ChatMessage {
  id:          number;
  kingshot_id: string;
  nickname:    string;
  avatar_url:  string | null;
  message:     string;
  created_at:  string;
}

// ── 상태 ──────────────────────────────────────────────────────────
let authRecord:   AuthRecord | null = null;
let authToken:    string | null     = null;
let isAdmin       = false;
let assignments:  Assignment[]      = [];
let activeScenario = 0;
let editingId:    number | null     = null;
let detailAssignmentId: number | null = null;
let pendingLookup: { nickname: string; avatar_url: string | null; city_level: number | null; power: number | null; alliance_abbr: string | null } | null = null;
let dragSourceId: number | null     = null;
let cdTimerId:    ReturnType<typeof setInterval> | null = null;
let lastChatDate  = '';  // 마지막으로 표시된 날짜 (날짜 구분선 중복 방지)
let lastChatKid   = '';
let lastChatGroup: HTMLElement | null = null;
const recentSentIds = new Set<number>(); // 즉시 추가한 메시지 id — Realtime 중복 방지

// ── 헬퍼 ──────────────────────────────────────────────────────────
function readAuth(): { token: string; record: AuthRecord } | null {
  try {
    const raw = localStorage.getItem(AUTH_KEY);
    if (!raw) return null;
    const obj = JSON.parse(raw);
    if (!obj?.token || !obj?.record?.kingshot_id) return null;
    return { token: obj.token as string, record: obj.record as AuthRecord };
  } catch { return null; }
}

function initial(nick: string | null): string {
  return (nick?.[0] ?? '?').toUpperCase();
}

function avatarHtml(url: string | null, nick: string | null, size: 'lg' | 'sm'): string {
  const cls = size === 'lg' ? 'st-rep-avatar' : 'st-member-avatar';
  const ini = initial(nick);
  if (url) {
    const px = size === 'lg' ? 84 : 38;
    return `<div class="${cls}"><img src="${escHtml(url)}" alt="${escHtml(nick ?? '')}" width="${px}" height="${px}" loading="lazy" onerror="this.parentElement.textContent='${escHtml(ini)}';this.remove()"></div>`;
  }
  return `<div class="${cls}">${escHtml(ini)}</div>`;
}

function escHtml(s: string): string {
  return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

function fmtTime(iso: string): string {
  const d = new Date(iso);
  const h = d.getHours().toString().padStart(2, '0');
  const m = d.getMinutes().toString().padStart(2, '0');
  return `${h}:${m}`;
}

function fmtDate(iso: string): string {
  const d = new Date(iso);
  return `${d.getFullYear()}.${(d.getMonth()+1).toString().padStart(2,'0')}.${d.getDate().toString().padStart(2,'0')}`;
}

function arrowSvg(): string {
  return `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"></polyline></svg>`;
}

function plusSvg(sz = 24): string {
  return `<svg width="${sz}" height="${sz}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>`;
}

// ── EF 호출 ──────────────────────────────────────────────────────
async function callFn(body: Record<string, unknown>): Promise<any> {
  const res = await fetch(STRATEGY_FN, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      apikey: SUPABASE_ANON_KEY,
      Authorization: 'Bearer ' + SUPABASE_ANON_KEY,
    },
    body: JSON.stringify(body),
  });
  return res.json();
}

// ── Supabase anon REST 조회 ───────────────────────────────────────
async function fetchAssignments(): Promise<Assignment[]> {
  const res = await fetch(
    `${DB_BASE}/strategy_assignments?select=id,group_id,is_leader,display_order,kingshot_id,nickname,avatar_url,city_level,power,alliance_abbr&order=group_id.asc,is_leader.desc,display_order.asc`,
    { headers: { apikey: SUPABASE_ANON_KEY, Authorization: 'Bearer ' + SUPABASE_ANON_KEY } },
  );
  if (!res.ok) return [];
  return res.json();
}

async function checkAdmin(kingshotId: string): Promise<boolean> {
  const res = await fetch(
    `${DB_BASE}/strategy_admins?kingshot_id=eq.${encodeURIComponent(kingshotId)}&select=kingshot_id`,
    { headers: { apikey: SUPABASE_ANON_KEY, Authorization: 'Bearer ' + SUPABASE_ANON_KEY, Accept: 'application/vnd.pgrst.object+json' } },
  );
  return res.status === 200;
}

// ── Gate UI ──────────────────────────────────────────────────────
const gateEl     = document.getElementById('st-gate')!;
const gateBtnEl  = document.getElementById('st-gate-btn')!;
const gateStatus = document.getElementById('st-gate-status')!;
const mainEl     = document.getElementById('st-main')!;
const loadingEl  = document.getElementById('st-loading')!;
const flowGrid   = document.getElementById('st-flow-grid')!;

function showGate(msg?: string) {
  gateEl.hidden  = false;
  mainEl.hidden  = true;
  if (msg) { gateStatus.textContent = msg; gateStatus.hidden = false; }
  else        { gateStatus.hidden = true; }
}

function showMain() {
  gateEl.hidden  = true;
  mainEl.hidden  = false;
}

function setLoading(on: boolean) {
  loadingEl.hidden = !on;
  flowGrid.hidden  = on;
}

// ── 시나리오 탭 ─────────────────────────────────────────────────
const tabsEl   = document.getElementById('st-tabs')!;
const descEl   = document.getElementById('st-scenario-desc')!;

tabsEl.querySelectorAll<HTMLButtonElement>('[data-scenario-idx]').forEach((btn) => {
  btn.addEventListener('click', () => {
    const idx = Number(btn.dataset.scenarioIdx);
    setScenario(idx);
  });
});

function setScenario(idx: number) {
  activeScenario = idx;
  tabsEl.querySelectorAll<HTMLButtonElement>('[data-scenario-idx]').forEach((btn, i) => {
    const active = i === idx;
    btn.classList.toggle('is-active', active);
    btn.setAttribute('aria-selected', String(active));
  });
  const descKey = SCENARIOS[idx].descKey;
  descEl.dataset.i18n = descKey;
  descEl.textContent  = t(descKey);
  if (assignments.length > 0) renderFlowGrid();
}

// ── 플로우 그리드 렌더 ────────────────────────────────────────────
function groupAssignments(): Record<string, { leader: Assignment | null; members: Assignment[] }> {
  const result: Record<string, { leader: Assignment | null; members: Assignment[] }> = {};
  for (const a of assignments) {
    if (!result[a.group_id]) result[a.group_id] = { leader: null, members: [] };
    if (a.is_leader) result[a.group_id].leader = a;
    else             result[a.group_id].members.push(a);
  }
  return result;
}

function renderFlowGrid() {
  const scenario  = SCENARIOS[activeScenario];
  const cols      = scenario.columns as readonly string[];
  const grouped   = groupAssignments();
  const numCols   = cols.length;

  // grid-template-columns: 컬럼 + 화살표 교차
  const tpl: string[] = [];
  for (let i = 0; i < numCols; i++) {
    if (i > 0) tpl.push('30px');
    tpl.push('minmax(0, 1fr)');
  }
  flowGrid.style.gridTemplateColumns = tpl.join(' ');

  const cells: string[] = [];
  for (let i = 0; i < numCols; i++) {
    if (i > 0) {
      cells.push(`<div class="st-flow-arrow">${arrowSvg()}</div>`);
    }
    const gid   = cols[i];
    const badgeCls = BADGE_CLS[i] ?? 'st-badge-1';
    cells.push(buildColumnHtml(grouped[gid] ?? { leader: null, members: [] }, gid, i + 1, badgeCls));
  }

  flowGrid.innerHTML = cells.join('');

  // + 버튼 핸들러는 항상 등록 (어드민 여부 무관)
  setupEditHandlers();
  // 드래그는 어드민만
  if (isAdmin) setupDragDrop();
}

function buildColumnHtml(
  data: { leader: Assignment | null; members: Assignment[] },
  gid:  string,
  order: number,
  badgeCls: string,
): string {
  const { leader, members } = data;
  const adminAttr = isAdmin ? `draggable="true"` : '';

  /* 집결장 블록 */
  const leaderLabel = t('strategy.grid.leaderLabel');
  const leaderAdd   = t('strategy.grid.leaderAdd');
  const memberAdd   = t('strategy.grid.memberAdd');
  const slotEmpty   = t('strategy.grid.slotEmpty');

  let heroBlock: string;
  if (!leader) {
    heroBlock = `<div class="st-hero-block"><div class="st-rep-empty">${escHtml(slotEmpty)}</div></div>`;
  } else if (leader.kingshot_id) {
    heroBlock = `
      <div class="st-hero-block" data-assignment-id="${leader.id}" ${adminAttr}>
        <div class="st-card-num ${badgeCls}">${order}</div>
        <div class="st-rep-label">${escHtml(leaderLabel)}</div>
        ${avatarHtml(leader.avatar_url, leader.nickname, 'lg')}
        <div class="st-rep-name">${escHtml(leader.nickname ?? '')}</div>
        ${leader.city_level ? `<div class="st-rep-tc">TC ${leader.city_level}</div>` : ''}
        ${isAdmin ? '<div class="st-drag-hint" aria-hidden="true"><svg width="8" height="14" viewBox="0 0 8 14" fill="currentColor"><circle cx="2" cy="2" r="1.5"/><circle cx="6" cy="2" r="1.5"/><circle cx="2" cy="7" r="1.5"/><circle cx="6" cy="7" r="1.5"/><circle cx="2" cy="12" r="1.5"/><circle cx="6" cy="12" r="1.5"/></svg></div>' : ''}
      </div>`;
  } else {
    /* 배정 없음 — 등록 버튼 (인증 사용자 모두에게 표시, 저장은 EF에서 권한 체크) */
    heroBlock = `
      <div class="st-hero-block" data-assignment-id="${leader.id}">
        <div class="st-card-num ${badgeCls}">${order}</div>
        <div class="st-rep-label">${escHtml(leaderLabel)}</div>
        <button type="button" class="st-rep-add-btn" data-id="${leader.id}" aria-label="${escHtml(leaderAdd)}">${plusSvg(26)}</button>
        <span class="st-rep-hint">${escHtml(leaderAdd)}</span>
      </div>`;
  }

  /* 집결원 목록 */
  const memberRows = members.map((m) => {
    if (!m.kingshot_id) return ''; // 빈 슬롯은 렌더 안 함 (어드민 버튼으로 대체)
    return `
      <div class="st-member" data-assignment-id="${m.id}" ${adminAttr}>
        ${avatarHtml(m.avatar_url, m.nickname, 'sm')}
        <span class="st-member-name">${escHtml(m.nickname ?? '')}</span>
        ${m.city_level ? `<span class="st-member-tc">TC ${m.city_level}</span>` : ''}
        ${isAdmin ? '<div class="st-drag-hint" aria-hidden="true"><svg width="8" height="12" viewBox="0 0 8 12" fill="currentColor"><circle cx="2" cy="2" r="1.5"/><circle cx="6" cy="2" r="1.5"/><circle cx="2" cy="6" r="1.5"/><circle cx="6" cy="6" r="1.5"/><circle cx="2" cy="10" r="1.5"/><circle cx="6" cy="10" r="1.5"/></svg></div>' : ''}
      </div>`;
  }).join('');

  /* 집결원 등록 버튼 (인증 사용자 모두에게 표시) */
  const addMemberBtn = `<button type="button" class="st-member-add-row" data-add-member="${escHtml(gid)}" aria-label="${escHtml(memberAdd)}">
       <div class="st-member-add-icon">${plusSvg(12)}</div>
       ${escHtml(memberAdd)}
     </button>`;

  return `
    <div class="st-col">
      <div class="st-card">
        ${heroBlock}
        <div class="st-members">
          ${memberRows}
          ${addMemberBtn}
        </div>
      </div>
    </div>`;
}

