---
// 거점 방향 컴파스 SVG — 동서남북 4 cardinal 위치 + 캐슬 중앙.
// 현재 거점 슬롯에 해당하는 dot 만 활성 강조.
import type { CbTargetSlot } from '@/lib/castle-battle/types';
import { SLOT_COMPASS } from '@/lib/castle-battle/types';

interface Props {
  slot: CbTargetSlot;
}
const { slot } = Astro.props;

const turretSlots: CbTargetSlot[] = [
  'turret_north',
  'turret_east',
  'turret_south',
  'turret_west',
];
const isCastle = slot === 'castle';
---

<svg class="cb-compass" viewBox="0 0 24 24" aria-hidden="true">
  <circle class="cb-compass-ring" cx="12" cy="12" r="10.5" />
  {turretSlots.map((ts) => {
    const pos = SLOT_COMPASS[ts];
    const isActive = !isCastle && ts === slot;
    return (
      <circle
        class:list={['cb-compass-dot', { 'is-active': isActive }]}
        cx={pos.cx}
        cy={pos.cy}
        r={isActive ? 2.8 : 1.8}
      />
    );
  })}
  {isCastle && (
    <circle class="cb-compass-dot is-active" cx="12" cy="12" r="3.2" />
  )}
</svg>
